/// Pending hard proof: binary function-pair units should be closed under
/// componentwise pointwise multiplication.
///
/// Informal proof:
/// - `function_pair_unit_iff_components` identifies a function-pair unit with
///   pointwise-unit first and second coordinates.
/// - `pointwise_mul_is_pointwise_unit` closes each coordinate under pointwise
///   multiplication.
/// - `function_pair_unit_of_components` packages the two coordinate facts back
///   into a function-pair unit.
///
/// The direct wrapper timed out while transporting the coordinate closure facts
/// through `function_pair_mul(p, q).first = pointwise_mul(p.first, q.first)` and
/// the matching second-coordinate equality. A longer attempt using explicit
/// inverse witnesses also timed out in the componentwise extensionality helpers.
from monoid import Monoid
from pair import Pair
from function_product_units import is_function_pair_unit
from function_product_algebra import function_pair_mul

/// The componentwise product of two function-pair units is a function-pair unit.
theorem function_pair_mul_is_function_pair_unit_pending[T, A: Monoid, B: Monoid](
    p: Pair[T -> A, T -> B],
    q: Pair[T -> A, T -> B]
) {
    is_function_pair_unit(p) and is_function_pair_unit(q) implies
    is_function_pair_unit(function_pair_mul(p, q))
}
