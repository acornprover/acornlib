from nat import Nat
from fin import Fin
from add import Add
from zero import Zero
from neg import Neg
from add_semigroup import AddSemigroup
from add_comm_semigroup import AddCommSemigroup
from add_monoid import AddMonoid
from add_group import AddGroup
from add_comm_group import AddCommGroup
from ring import Ring
from semiring import Semiring
from module import Module, module_smul_one, module_smul_zero_left
from functions import function_extensionality
from fin_sum import fin_sum, fin_pointwise_add, fin_zero_function, fin_sum_add,
    fin_sum_pointwise_eq, fin_sum_zero_function, fin_sum_zero_of_bound_zero

/// An `m` by `n` matrix with entries in `A`, indexed by finite row and column sets.
structure FinMatrix[A, m: Nat, n: Nat] {
    /// The entry function of the matrix.
    entry: (Fin[m], Fin[n]) -> A
}

/// The entry of a finite matrix.
define fin_matrix_entry[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) -> A {
    a.entry(i, j)
}

/// The entry function of the zero matrix.
define fin_matrix_zero_entry[A: Zero](m: Nat, n: Nat, i: Fin[m], j: Fin[n]) -> A {
    A.0
}

/// The zero `m` by `n` matrix.
define fin_matrix_zero[A: Zero](m: Nat, n: Nat) -> FinMatrix[A, m, n] {
    FinMatrix[A, m, n].new(fin_matrix_zero_entry[A](m, n))
}

/// The entry function of the pointwise sum of two matrices.
define fin_matrix_add_entry[A: Add](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) -> A {
    a.entry(i, j) + b.entry(i, j)
}

/// Pointwise addition of `m` by `n` matrices.
define fin_matrix_add[A: Add](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n]) -> FinMatrix[A, m, n] {
    FinMatrix[A, m, n].new(fin_matrix_add_entry[A](m, n, a, b))
}

/// The entry function of the pointwise negation of a matrix.
define fin_matrix_neg_entry[A: Neg](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) -> A {
    -a.entry(i, j)
}

/// Pointwise negation of an `m` by `n` matrix.
define fin_matrix_neg[A: Neg](m: Nat, n: Nat, a: FinMatrix[A, m, n]) -> FinMatrix[A, m, n] {
    FinMatrix[A, m, n].new(fin_matrix_neg_entry[A](m, n, a))
}

/// The entry function of the pointwise difference of two matrices.
define fin_matrix_sub_entry[A: AddGroup](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) -> A {
    a.entry(i, j) - b.entry(i, j)
}

/// Pointwise subtraction of `m` by `n` matrices.
define fin_matrix_sub[A: AddGroup](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n]) -> FinMatrix[A, m, n] {
    FinMatrix[A, m, n].new(fin_matrix_sub_entry[A](m, n, a, b))
}

/// The entry function of the scalar multiple of a matrix.
define fin_matrix_smul_entry[R: Ring, M: AddCommGroup](
    carrier: Module[R, M], m: Nat, n: Nat, r: R, a: FinMatrix[M, m, n], i: Fin[m], j: Fin[n]
) -> M {
    carrier.smul(r, a.entry(i, j))
}

/// Scalar multiplication of a matrix with entries in a module.
define fin_matrix_smul[R: Ring, M: AddCommGroup](
    carrier: Module[R, M], m: Nat, n: Nat, r: R, a: FinMatrix[M, m, n]
) -> FinMatrix[M, m, n] {
    FinMatrix[M, m, n].new(fin_matrix_smul_entry[R, M](carrier, m, n, r, a))
}

/// The entry function of the transpose of a matrix.
define fin_matrix_transpose_entry[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], j: Fin[n], i: Fin[m]) -> A {
    a.entry(i, j)
}

/// The transpose of an `m` by `n` matrix.
define fin_matrix_transpose[A](m: Nat, n: Nat, a: FinMatrix[A, m, n]) -> FinMatrix[A, n, m] {
    FinMatrix[A, n, m].new(fin_matrix_transpose_entry[A](m, n, a))
}

/// The `i`th row of an `m` by `n` matrix, as a coordinate vector of length `n`.
define fin_matrix_row[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) -> A {
    a.entry(i, j)
}

/// The `j`th column of an `m` by `n` matrix, as a coordinate vector of length `m`.
define fin_matrix_col[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], j: Fin[n], i: Fin[m]) -> A {
    a.entry(i, j)
}

/// The `k`th summand in the product of an `m` by `n` matrix and an `n` by `p` matrix.
define fin_matrix_mul_term[S: Semiring](
    m: Nat,
    n: Nat,
    p: Nat,
    a: FinMatrix[S, m, n],
    b: FinMatrix[S, n, p],
    i: Fin[m],
    j: Fin[p],
    k: Fin[n]
) -> S {
    fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, b, k, j)
}

/// The entry function of the product of an `m` by `n` matrix and an `n` by `p` matrix.
define fin_matrix_mul_entry[S: Semiring](
    m: Nat,
    n: Nat,
    p: Nat,
    a: FinMatrix[S, m, n],
    b: FinMatrix[S, n, p],
    i: Fin[m],
    j: Fin[p]
) -> S {
    fin_sum[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j))
}

/// The product entry of an `m` by `n` matrix and an `n` by `p` matrix.
define fin_matrix_mul[S: Semiring](
    m: Nat,
    n: Nat,
    p: Nat,
    a: FinMatrix[S, m, n],
    b: FinMatrix[S, n, p],
    i: Fin[m],
    j: Fin[p]
) -> S {
    fin_matrix_mul_entry[S](m, n, p, a, b, i, j)
}

/// Matrix entry agrees with the underlying entry function.
theorem fin_matrix_entry_apply[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, a, i, j) = a.entry(i, j)
}

/// The zero matrix has zero in every entry.
theorem fin_matrix_zero_apply[A: Zero](m: Nat, n: Nat, i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_zero[A](m, n), i, j) = A.0
}

/// Pointwise matrix addition agrees with addition of entries.
theorem fin_matrix_add_apply[A: Add](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, b), i, j) =
        fin_matrix_entry[A](m, n, a, i, j) + fin_matrix_entry[A](m, n, b, i, j)
} by {
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, b), i, j) = fin_matrix_add_entry[A](m, n, a, b, i, j)
    fin_matrix_add_entry[A](m, n, a, b, i, j) =
        fin_matrix_entry[A](m, n, a, i, j) + fin_matrix_entry[A](m, n, b, i, j)
}

/// Pointwise matrix negation agrees with negation of entries.
theorem fin_matrix_neg_apply[A: Neg](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_neg[A](m, n, a), i, j) = -fin_matrix_entry[A](m, n, a, i, j)
}

/// Pointwise matrix subtraction agrees with subtraction of entries.
theorem fin_matrix_sub_apply[A: AddGroup](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_sub[A](m, n, a, b), i, j) =
        fin_matrix_entry[A](m, n, a, i, j) - fin_matrix_entry[A](m, n, b, i, j)
} by {
    fin_matrix_entry[A](m, n, fin_matrix_sub[A](m, n, a, b), i, j) = fin_matrix_sub_entry[A](m, n, a, b, i, j)
    fin_matrix_sub_entry[A](m, n, a, b, i, j) =
        fin_matrix_entry[A](m, n, a, i, j) - fin_matrix_entry[A](m, n, b, i, j)
}

/// Matrix scalar multiplication agrees with scalar multiplication of entries.
theorem fin_matrix_smul_apply[R: Ring, M: AddCommGroup](
    carrier: Module[R, M], m: Nat, n: Nat, r: R, a: FinMatrix[M, m, n], i: Fin[m], j: Fin[n]
) {
    fin_matrix_entry[M](m, n, fin_matrix_smul[R, M](carrier, m, n, r, a), i, j) =
        carrier.smul(r, fin_matrix_entry[M](m, n, a, i, j))
} by {
    fin_matrix_entry[M](m, n, fin_matrix_smul[R, M](carrier, m, n, r, a), i, j) =
        fin_matrix_smul_entry[R, M](carrier, m, n, r, a, i, j)
    fin_matrix_smul_entry[R, M](carrier, m, n, r, a, i, j) = carrier.smul(r, fin_matrix_entry[M](m, n, a, i, j))
}

/// Matrix transposition swaps indices.
theorem fin_matrix_transpose_apply[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](n, m, fin_matrix_transpose[A](m, n, a), j, i) = fin_matrix_entry[A](m, n, a, i, j)
}

/// Matrix rows agree with the corresponding entries.
theorem fin_matrix_row_apply[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_row[A](m, n, a, i, j) = fin_matrix_entry[A](m, n, a, i, j)
}

/// Matrix columns agree with the corresponding entries.
theorem fin_matrix_col_apply[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], j: Fin[n], i: Fin[m]) {
    fin_matrix_col[A](m, n, a, j, i) = fin_matrix_entry[A](m, n, a, i, j)
}

/// A matrix product is the finite sum of its multiplication terms.
theorem fin_matrix_mul_apply[S: Semiring](
    m: Nat,
    n: Nat,
    p: Nat,
    a: FinMatrix[S, m, n],
    b: FinMatrix[S, n, p],
    i: Fin[m],
    j: Fin[p]
) {
    fin_matrix_mul[S](m, n, p, a, b, i, j) =
        fin_sum[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j))
}

/// A zero inner dimension gives the zero product entry.
theorem fin_matrix_mul_inner_zero[S: Semiring](
    m: Nat,
    n: Nat,
    p: Nat,
    a: FinMatrix[S, m, n],
    b: FinMatrix[S, n, p],
    i: Fin[m],
    j: Fin[p]
) {
    n = Nat.0 implies fin_matrix_mul[S](m, n, p, a, b, i, j) = S.0
} by {
    if n = Nat.0 {
        fin_matrix_mul[S](m, n, p, a, b, i, j) =
            fin_sum[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j))
        fin_sum_zero_of_bound_zero[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j))
    }
}

/// If the selected row of the left factor is zero, the product entry is zero.
theorem fin_matrix_mul_zero_left_row[S: Semiring](
    m: Nat, n: Nat, p: Nat, a: FinMatrix[S, m, n], b: FinMatrix[S, n, p], i: Fin[m], j: Fin[p]
) {
    (forall(k: Fin[n]) { fin_matrix_entry[S](m, n, a, i, k) = S.0 }) implies fin_matrix_mul[S](m, n, p, a, b, i, j) = S.0
} by {
    if forall(k: Fin[n]) { fin_matrix_entry[S](m, n, a, i, k) = S.0 } {
        forall(k: Fin[n]) {
            fin_matrix_mul_term[S](m, n, p, a, b, i, j, k) =
                fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, b, k, j)
            fin_matrix_entry[S](m, n, a, i, k) = S.0
            S.0 * fin_matrix_entry[S](n, p, b, k, j) = S.0
            fin_matrix_mul_term[S](m, n, p, a, b, i, j, k) = fin_zero_function[S](n, k)
        }
        fin_sum_pointwise_eq[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j), fin_zero_function[S](n))
        fin_matrix_mul[S](m, n, p, a, b, i, j) = fin_sum[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j))
        fin_sum[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j)) = fin_sum[S](n, fin_zero_function[S](n))
        fin_sum_zero_function[S](n)
        fin_sum[S](n, fin_zero_function[S](n)) = S.0
        fin_matrix_mul[S](m, n, p, a, b, i, j) = S.0
    }
}

/// If the selected column of the right factor is zero, the product entry is zero.
theorem fin_matrix_mul_zero_right_col[S: Semiring](
    m: Nat, n: Nat, p: Nat, a: FinMatrix[S, m, n], b: FinMatrix[S, n, p], i: Fin[m], j: Fin[p]
) {
    (forall(k: Fin[n]) { fin_matrix_entry[S](n, p, b, k, j) = S.0 }) implies fin_matrix_mul[S](m, n, p, a, b, i, j) = S.0
} by {
    if forall(k: Fin[n]) { fin_matrix_entry[S](n, p, b, k, j) = S.0 } {
        forall(k: Fin[n]) {
            fin_matrix_mul_term[S](m, n, p, a, b, i, j, k) =
                fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, b, k, j)
            fin_matrix_entry[S](n, p, b, k, j) = S.0
            fin_matrix_entry[S](m, n, a, i, k) * S.0 = S.0
            fin_matrix_mul_term[S](m, n, p, a, b, i, j, k) = fin_zero_function[S](n, k)
        }
        fin_sum_pointwise_eq[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j), fin_zero_function[S](n))
        fin_matrix_mul[S](m, n, p, a, b, i, j) = fin_sum[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j))
        fin_sum[S](n, fin_matrix_mul_term[S](m, n, p, a, b, i, j)) = fin_sum[S](n, fin_zero_function[S](n))
        fin_sum_zero_function[S](n)
        fin_sum[S](n, fin_zero_function[S](n)) = S.0
        fin_matrix_mul[S](m, n, p, a, b, i, j) = S.0
    }
}

/// Matrix multiplication distributes over pointwise addition in the right factor.
theorem fin_matrix_mul_add_right[S: Semiring](
    m: Nat,
    n: Nat,
    p: Nat,
    a: FinMatrix[S, m, n],
    b: FinMatrix[S, n, p],
    c: FinMatrix[S, n, p],
    i: Fin[m],
    j: Fin[p]
) {
    fin_matrix_mul[S](m, n, p, a, fin_matrix_add[S](n, p, b, c), i, j) =
        fin_matrix_mul[S](m, n, p, a, b, i, j) + fin_matrix_mul[S](m, n, p, a, c, i, j)
} by {
    let h = fin_matrix_mul_term[S](m, n, p, a, fin_matrix_add[S](n, p, b, c), i, j)
    let f = fin_matrix_mul_term[S](m, n, p, a, b, i, j)
    let g = fin_matrix_mul_term[S](m, n, p, a, c, i, j)
    forall(k: Fin[n]) {
        h(k) = fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, fin_matrix_add[S](n, p, b, c), k, j)
        fin_matrix_entry[S](n, p, fin_matrix_add[S](n, p, b, c), k, j) =
            fin_matrix_entry[S](n, p, b, k, j) + fin_matrix_entry[S](n, p, c, k, j)
        fin_matrix_entry[S](m, n, a, i, k) * (fin_matrix_entry[S](n, p, b, k, j) + fin_matrix_entry[S](n, p, c, k, j)) =
            fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, b, k, j) + fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, c, k, j)
        f(k) = fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, b, k, j)
        g(k) = fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, c, k, j)
        fin_pointwise_add[S](n, f, g, k) = f(k) + g(k)
        h(k) = fin_pointwise_add[S](n, f, g, k)
    }
    function_extensionality(h, fin_pointwise_add[S](n, f, g))
    fin_sum_add[S](n, f, g)
    fin_matrix_mul[S](m, n, p, a, fin_matrix_add[S](n, p, b, c), i, j) = fin_sum[S](n, h)
    fin_matrix_mul[S](m, n, p, a, b, i, j) = fin_sum[S](n, f)
    fin_matrix_mul[S](m, n, p, a, c, i, j) = fin_sum[S](n, g)
}

/// Matrix multiplication distributes over pointwise addition in the left factor.
theorem fin_matrix_mul_add_left[S: Semiring](
    m: Nat,
    n: Nat,
    p: Nat,
    a: FinMatrix[S, m, n],
    b: FinMatrix[S, m, n],
    c: FinMatrix[S, n, p],
    i: Fin[m],
    j: Fin[p]
) {
    fin_matrix_mul[S](m, n, p, fin_matrix_add[S](m, n, a, b), c, i, j) =
        fin_matrix_mul[S](m, n, p, a, c, i, j) + fin_matrix_mul[S](m, n, p, b, c, i, j)
} by {
    let h = fin_matrix_mul_term[S](m, n, p, fin_matrix_add[S](m, n, a, b), c, i, j)
    let f = fin_matrix_mul_term[S](m, n, p, a, c, i, j)
    let g = fin_matrix_mul_term[S](m, n, p, b, c, i, j)
    forall(k: Fin[n]) {
        h(k) = fin_matrix_entry[S](m, n, fin_matrix_add[S](m, n, a, b), i, k) * fin_matrix_entry[S](n, p, c, k, j)
        fin_matrix_entry[S](m, n, fin_matrix_add[S](m, n, a, b), i, k) =
            fin_matrix_entry[S](m, n, a, i, k) + fin_matrix_entry[S](m, n, b, i, k)
        (fin_matrix_entry[S](m, n, a, i, k) + fin_matrix_entry[S](m, n, b, i, k)) * fin_matrix_entry[S](n, p, c, k, j) =
            fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, c, k, j) + fin_matrix_entry[S](m, n, b, i, k) * fin_matrix_entry[S](n, p, c, k, j)
        f(k) = fin_matrix_entry[S](m, n, a, i, k) * fin_matrix_entry[S](n, p, c, k, j)
        g(k) = fin_matrix_entry[S](m, n, b, i, k) * fin_matrix_entry[S](n, p, c, k, j)
        fin_pointwise_add[S](n, f, g, k) = f(k) + g(k)
        h(k) = fin_pointwise_add[S](n, f, g, k)
    }
    function_extensionality(h, fin_pointwise_add[S](n, f, g))
    fin_sum_add[S](n, f, g)
    fin_matrix_mul[S](m, n, p, fin_matrix_add[S](m, n, a, b), c, i, j) = fin_sum[S](n, h)
    fin_matrix_mul[S](m, n, p, a, c, i, j) = fin_sum[S](n, f)
    fin_matrix_mul[S](m, n, p, b, c, i, j) = fin_sum[S](n, g)
}

/// Pointwise matrix addition is associative at each entry.
theorem fin_matrix_add_assoc_at[A: AddSemigroup](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n], c: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, fin_matrix_add[A](m, n, b, c)), i, j) =
        fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, fin_matrix_add[A](m, n, a, b), c), i, j)
} by {
    fin_matrix_add_apply[A](m, n, a, fin_matrix_add[A](m, n, b, c), i, j)
    fin_matrix_add_apply[A](m, n, b, c, i, j)
    fin_matrix_add_apply[A](m, n, fin_matrix_add[A](m, n, a, b), c, i, j)
    fin_matrix_add_apply[A](m, n, a, b, i, j)
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, fin_matrix_add[A](m, n, b, c)), i, j) =
        fin_matrix_entry[A](m, n, a, i, j) + (fin_matrix_entry[A](m, n, b, i, j) + fin_matrix_entry[A](m, n, c, i, j))
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, fin_matrix_add[A](m, n, a, b), c), i, j) =
        (fin_matrix_entry[A](m, n, a, i, j) + fin_matrix_entry[A](m, n, b, i, j)) + fin_matrix_entry[A](m, n, c, i, j)
    fin_matrix_entry[A](m, n, a, i, j) + (fin_matrix_entry[A](m, n, b, i, j) + fin_matrix_entry[A](m, n, c, i, j)) =
        (fin_matrix_entry[A](m, n, a, i, j) + fin_matrix_entry[A](m, n, b, i, j)) + fin_matrix_entry[A](m, n, c, i, j)
}

/// Pointwise matrix addition is commutative at each entry.
theorem fin_matrix_add_comm_at[A: AddCommSemigroup](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, b), i, j) = fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, b, a), i, j)
} by {
    fin_matrix_add_apply[A](m, n, a, b, i, j)
    fin_matrix_add_apply[A](m, n, b, a, i, j)
    fin_matrix_entry[A](m, n, a, i, j) + fin_matrix_entry[A](m, n, b, i, j) =
        fin_matrix_entry[A](m, n, b, i, j) + fin_matrix_entry[A](m, n, a, i, j)
}

/// Adding the zero matrix on the right changes nothing at each entry.
theorem fin_matrix_add_zero_right_at[A: AddMonoid](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, fin_matrix_zero[A](m, n)), i, j) = fin_matrix_entry[A](m, n, a, i, j)
} by {
    fin_matrix_add_apply[A](m, n, a, fin_matrix_zero[A](m, n), i, j)
    fin_matrix_zero_apply[A](m, n, i, j)
    fin_matrix_entry[A](m, n, a, i, j) + A.0 = fin_matrix_entry[A](m, n, a, i, j)
}

/// Adding the zero matrix on the left changes nothing at each entry.
theorem fin_matrix_add_zero_left_at[A: AddMonoid](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, fin_matrix_zero[A](m, n), a), i, j) = fin_matrix_entry[A](m, n, a, i, j)
} by {
    fin_matrix_add_apply[A](m, n, fin_matrix_zero[A](m, n), a, i, j)
    fin_matrix_zero_apply[A](m, n, i, j)
    A.0 + fin_matrix_entry[A](m, n, a, i, j) = fin_matrix_entry[A](m, n, a, i, j)
}

/// Pointwise matrix negation is a right additive inverse at each entry.
theorem fin_matrix_add_neg_right_at[A: AddGroup](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, fin_matrix_neg[A](m, n, a)), i, j) =
        fin_matrix_entry[A](m, n, fin_matrix_zero[A](m, n), i, j)
} by {
    fin_matrix_add_apply[A](m, n, a, fin_matrix_neg[A](m, n, a), i, j)
    fin_matrix_neg_apply[A](m, n, a, i, j)
    fin_matrix_zero_apply[A](m, n, i, j)
    fin_matrix_entry[A](m, n, a, i, j) + -fin_matrix_entry[A](m, n, a, i, j) = A.0
}

/// Pointwise matrix subtraction is addition with pointwise negation at each entry.
theorem fin_matrix_sub_eq_add_neg_at[A: AddGroup](m: Nat, n: Nat, a: FinMatrix[A, m, n], b: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_sub[A](m, n, a, b), i, j) =
        fin_matrix_entry[A](m, n, fin_matrix_add[A](m, n, a, fin_matrix_neg[A](m, n, b)), i, j)
} by {
    fin_matrix_sub_apply[A](m, n, a, b, i, j)
    fin_matrix_add_apply[A](m, n, a, fin_matrix_neg[A](m, n, b), i, j)
    fin_matrix_neg_apply[A](m, n, b, i, j)
    fin_matrix_entry[A](m, n, a, i, j) - fin_matrix_entry[A](m, n, b, i, j) =
        fin_matrix_entry[A](m, n, a, i, j) + -fin_matrix_entry[A](m, n, b, i, j)
}

/// Transposing a matrix twice gives the original entry.
theorem fin_matrix_transpose_transpose_at[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[A](m, n, fin_matrix_transpose[A](n, m, fin_matrix_transpose[A](m, n, a)), i, j) =
        fin_matrix_entry[A](m, n, a, i, j)
} by {
    fin_matrix_transpose_apply[A](n, m, fin_matrix_transpose[A](m, n, a), j, i)
    fin_matrix_transpose_apply[A](m, n, a, i, j)
}

/// Rows of the transpose are columns of the original matrix at each coordinate.
theorem fin_matrix_row_transpose_at[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], j: Fin[n], i: Fin[m]) {
    fin_matrix_row[A](n, m, fin_matrix_transpose[A](m, n, a), j, i) = fin_matrix_col[A](m, n, a, j, i)
} by {
    fin_matrix_row_apply[A](n, m, fin_matrix_transpose[A](m, n, a), j, i)
    fin_matrix_transpose_apply[A](m, n, a, i, j)
    fin_matrix_col_apply[A](m, n, a, j, i)
}

/// Columns of the transpose are rows of the original matrix at each coordinate.
theorem fin_matrix_col_transpose_at[A](m: Nat, n: Nat, a: FinMatrix[A, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_col[A](n, m, fin_matrix_transpose[A](m, n, a), i, j) = fin_matrix_row[A](m, n, a, i, j)
} by {
    fin_matrix_col_apply[A](n, m, fin_matrix_transpose[A](m, n, a), i, j)
    fin_matrix_transpose_apply[A](m, n, a, i, j)
    fin_matrix_row_apply[A](m, n, a, i, j)
}

/// The identity scalar fixes every matrix entry.
theorem fin_matrix_smul_one_at[R: Ring, M: AddCommGroup](carrier: Module[R, M], m: Nat, n: Nat, a: FinMatrix[M, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[M](m, n, fin_matrix_smul[R, M](carrier, m, n, R.1, a), i, j) = fin_matrix_entry[M](m, n, a, i, j)
} by {
    fin_matrix_smul_apply[R, M](carrier, m, n, R.1, a, i, j)
    module_smul_one(carrier, fin_matrix_entry[M](m, n, a, i, j))
}

/// The zero scalar annihilates every matrix entry.
theorem fin_matrix_smul_zero_left_at[R: Ring, M: AddCommGroup](carrier: Module[R, M], m: Nat, n: Nat, a: FinMatrix[M, m, n], i: Fin[m], j: Fin[n]) {
    fin_matrix_entry[M](m, n, fin_matrix_smul[R, M](carrier, m, n, R.0, a), i, j) = M.0
} by {
    fin_matrix_smul_apply[R, M](carrier, m, n, R.0, a, i, j)
    module_smul_zero_left(carrier, fin_matrix_entry[M](m, n, a, i, j))
}
