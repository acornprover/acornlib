/// `a` is the least element of `is_in_pair(a, b)` iff `a <= b`.
theorem is_least_is_in_pair_left_iff_lte[P: PartialOrder](a: P, b: P) {
    is_least(is_in_pair(a, b), a) iff a <= b
} by {
    if is_least(is_in_pair(a, b), a) {
