/// If `b <= a`, then `b` is the infimum of `is_in_pair(a, b)`.
theorem is_glb_is_in_pair_of_lte_right[P: PartialOrder](a: P, b: P) {
    b <= a implies is_glb(is_in_pair(a, b), b)
