from list.list_functional import reverse
from list.list_sum import List, map, sum
from add_comm_monoid import AddCommMonoid

/// Specialized at-point list induction wrapper. Keeping the target list as an
/// explicit theorem parameter avoids repeatedly asking search to instantiate the
/// induction conclusion through a larger list predicate.
theorem list_reverse_induction_at[T](p: List[T] -> Bool, items: List[T]) {
    p(List.nil[T]) and (forall(head: T, tail: List[T]) {
        p(tail) implies p(List.cons(head, tail))
    }) implies p(items)
} by {
    if p(List.nil[T]) and forall(head: T, tail: List[T]) { p(tail) implies p(List.cons(head, tail)) } {
        List.induction(p)
        p(items)
    }
}

/// Reversing an empty list is empty.
theorem reverse_nil[T] {
    reverse(List.nil[T]) = List.nil[T]
}

/// Reversing a cons appends the head to the reversed tail.
theorem reverse_cons[T](head: T, tail: List[T]) {
    reverse(List.cons(head, tail)) = reverse(tail).append(head)
}

/// Reversing a singleton is itself.
theorem reverse_singleton[T](x: T) {
    reverse(List.singleton(x)) = List.singleton(x)
} by {
    List.singleton(x) = List.cons(x, List.nil[T])
    reverse(List.nil[T]) = List.nil[T]
    List.nil[T].append(x) = List.singleton(x)
    reverse(List.singleton(x)) = List.nil[T].append(x)
}

/// Reversing a right-append puts the last element first.
theorem reverse_append[T](initial: List[T], last: T) {
    reverse(initial.append(last)) = List.cons(last, reverse(initial))
} by {
    initial.append(last) = initial + List.singleton(last)
    reverse(initial + List.singleton(last)) = reverse(List.singleton(last)) + reverse(initial)
    reverse(List.singleton(last)) = List.singleton(last)
    List.singleton(last) + reverse(initial) = List.cons(last, List.nil[T]) + reverse(initial)
    List.nil[T] + reverse(initial) = reverse(initial)
    List.cons(last, List.nil[T]) + reverse(initial) = List.cons(last, reverse(initial))
}

/// If the reverse is empty, the original list is empty.
theorem reverse_eq_nil_imp_nil[T](list: List[T]) {
    reverse(list) = List.nil[T] implies list = List.nil[T]
}

/// Reverse is empty exactly when the original list is empty.
theorem reverse_eq_nil_iff[T](list: List[T]) {
    (reverse(list) = List.nil[T]) = (list = List.nil[T])
} by {
    if reverse(list) = List.nil[T] {
        reverse_eq_nil_imp_nil(list)
        list = List.nil[T]
    }
    if list = List.nil[T] {
        reverse(list) = reverse(List.nil[T])
        reverse(List.nil[T]) = List.nil[T]
    }
}

/// Reverse is injective.
theorem reverse_injective[T](left: List[T], right: List[T]) {
    reverse(left) = reverse(right) implies left = right
}

/// Reversed lists are equal exactly when the original lists are equal.
theorem reverse_eq_iff[T](left: List[T], right: List[T]) {
    (reverse(left) = reverse(right)) = (left = right)
}

/// Predicate form of reverse/map commutation, with the function argument first
/// so it can be partially applied to a `List[T] -> Bool` induction predicate.
define reverse_map_pred[T, U](f: T -> U, items: List[T]) -> Bool {
    reverse(map(items, f)) = map(reverse(items), f)
}

/// Unfolds the reverse/map commutation predicate.
theorem reverse_map_pred_eq[T, U](items: List[T], f: T -> U) {
    reverse_map_pred(f, items) = (reverse(map(items, f)) = map(reverse(items), f))
}

/// Empty-list instance of reverse/map commutation.
theorem reverse_map_pred_nil[T, U](f: T -> U) {
    reverse_map_pred(f, List.nil[T])
} by {
    reverse_map_pred_eq[T, U](List.nil[T], f)
    map[T, U](List.nil[T], f) = List.nil[U]
    reverse[U](List.nil[U]) = List.nil[U]
    reverse[T](List.nil[T]) = List.nil[T]
    map[T, U](reverse(List.nil[T]), f) = List.nil[U]
    reverse_map_pred(f, List.nil[T])
}

/// Cons step for reverse/map commutation.
theorem reverse_map_pred_cons[T, U](head: T, tail: List[T], f: T -> U) {
    reverse_map_pred(f, tail) implies reverse_map_pred(f, List.cons(head, tail))
} by {
    if reverse_map_pred(f, tail) {
        reverse_map_pred_eq[T, U](tail, f)
        reverse_map_pred_eq[T, U](List.cons(head, tail), f)
        reverse(map[T, U](tail, f)) = map(reverse[T](tail), f)
        reverse(map[T, U](tail, f)).append(f(head)) = map(reverse[T](tail), f).append(f(head))
        map[T, U](reverse(tail).append(head), f) = map[T, U](reverse(tail), f).append(f(head))
        reverse[T](List.cons(head, tail)) = reverse[T](tail).append(head)
        map[T, U](List.cons(head, tail), f) = List.cons(f(head), map[T, U](tail, f))
        reverse[U](List.cons(f(head), map[T, U](tail, f))) = reverse(map[T, U](tail, f)).append(f(head))
        reverse(map(List.cons(head, tail), f)) = map(reverse(List.cons(head, tail)), f)
        reverse_map_pred(f, List.cons(head, tail))
    }
}

/// Reverse commutes with map.
theorem reverse_map[T, U](list: List[T], f: T -> U) {
    reverse(map(list, f)) = map(reverse(list), f)
} by {
    let p: List[T] -> Bool = reverse_map_pred(f)
    reverse_map_pred_nil[T, U](f)
    p(List.nil[T])
    forall(head: T, tail: List[T]) {
        if p(tail) {
            reverse_map_pred(f, tail)
            reverse_map_pred_cons[T, U](head, tail, f)
            reverse_map_pred(f, List.cons(head, tail))
            p(List.cons(head, tail))
        }
    }
    forall(head: T, tail: List[T]) { p(tail) implies p(List.cons(head, tail)) }
    list_reverse_induction_at[T](p, list)
    p(list)
    reverse_map_pred(f, list)
    reverse_map_pred_eq[T, U](list, f)
    reverse(map(list, f)) = map(reverse(list), f)
}

/// Map commutes with reverse.
theorem map_reverse[T, U](list: List[T], f: T -> U) {
    map(reverse(list), f) = reverse(map(list, f))
}

/// Mapping over a reversed list has the same membership image as mapping over the original list.
theorem map_reverse_contains[T, U](list: List[T], f: T -> U, y: U) {
    map(reverse(list), f).contains(y) = map(list, f).contains(y)
}

/// Symmetric length wrapper for reverse.
theorem reverse_length_eq[T](list: List[T]) {
    list.length = reverse(list).length
}

/// Symmetric sum wrapper for reverse.
theorem sum_reverse_eq[A: AddCommMonoid](list: List[A]) {
    sum(list) = sum(reverse(list))
}
