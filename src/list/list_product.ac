from list.list_base import List, map
from comm_monoid import CommMonoid

/// Computes the product of all elements in a list (requires elements to form
/// a commutative monoid). The product of the empty list is the monoid's
/// identity element.
define product[A: CommMonoid](items: List[A]) -> A {
    match items {
        List.nil {
            A.1
        }
        List.cons(head, tail) {
            head * product(tail)
        }
    }
}

/// The product of the empty list is the multiplicative identity.
theorem product_nil[A: CommMonoid] {
    product(List.nil[A]) = A.1
}

/// The product of a cons list factors as head times the product of the tail.
theorem product_cons[A: CommMonoid](head: A, tail: List[A]) {
    product(List.cons(head, tail)) = head * product(tail)
}

/// The product distributes over list concatenation.
theorem product_add[A: CommMonoid](left: List[A], right: List[A]) {
    product[A](left + right) = product[A](left) * product[A](right)
} by {
    define p(l: List[A]) -> Bool {
        product[A](l + right) = product[A](l) * product[A](right)
    }
    List.nil[A] + right = right
    product[A](List.nil[A]) = A.1
    A.1 * product[A](right) = product[A](right)
    p(List.nil[A])
    forall(head: A, tail: List[A]) {
        if p(tail) {
            List.cons(head, tail) + right = List.cons(head, tail + right)
            product[A](List.cons(head, tail + right)) = head * product[A](tail + right)
            product[A](tail + right) = product[A](tail) * product[A](right)
            product[A](List.cons(head, tail + right)) = head * (product[A](tail) * product[A](right))
            head * (product[A](tail) * product[A](right)) = (head * product[A](tail)) * product[A](right)
            product[A](List.cons(head, tail)) = head * product[A](tail)
            product[A](List.cons(head, tail) + right) = product[A](List.cons(head, tail)) * product[A](right)
            p(List.cons(head, tail))
        }
    }
    List.induction(function(l: List[A]) { p(l) })
    forall(l: List[A]) { p(l) }
    p(left)
}

/// The product of a singleton list is its only element.
theorem product_singleton[A: CommMonoid](x: A) {
    product[A](List.singleton(x)) = x
} by {
    List.singleton(x) = List.cons(x, List.nil[A])
    product[A](List.cons(x, List.nil[A])) = x * product[A](List.nil[A])
    product[A](List.nil[A]) = A.1
    x * A.1 = x
}

/// The product after appending one element on the right.
theorem product_append_elem[A: CommMonoid](initial: List[A], last: A) {
    product[A](initial.append(last)) = product[A](initial) * last
} by {
    initial.append(last) = initial + List.singleton(last)
    product_add(initial, List.singleton(last))
    product_singleton(last)
}

/// The product of a two-element list is the product of its elements.
theorem product_pair[A: CommMonoid](x: A, y: A) {
    product[A](List.cons(x, List.singleton(y))) = x * y
} by {
    product_cons(x, List.singleton(y))
    product_singleton(y)
}

/// Appending nil on the right does not change product.
theorem product_add_nil[A: CommMonoid](list: List[A]) {
    product[A](list + List.nil[A]) = product[A](list)
} by {
    product_add(list, List.nil[A])
    product_nil[A]
    product[A](list) * A.1 = product[A](list)
}

/// Appending nil on the left does not change product.
theorem product_nil_add[A: CommMonoid](list: List[A]) {
    product[A](List.nil[A] + list) = product[A](list)
}

/// The product of a mapped cons list factors at the mapped head.
theorem product_map_cons[T, A: CommMonoid](head: T, tail: List[T], f: T -> A) {
    product[A](map[T, A](List.cons(head, tail), f)) =
        f(head) * product[A](map[T, A](tail, f))
} by {
    map[T, A](List.cons(head, tail), f) = List.cons(f(head), map[T, A](tail, f))
    product_cons(f(head), map[T, A](tail, f))
}

/// The product of a mapped singleton list is the image of its element.
theorem product_map_singleton[T, A: CommMonoid](f: T -> A, x: T) {
    product[A](map[T, A](List.singleton(x), f)) = f(x)
} by {
    List.singleton(x) = List.cons(x, List.nil[T])
    map[T, A](List.nil[T], f) = List.nil[A]
    map[T, A](List.cons(x, List.nil[T]), f) = List.cons(f(x), List.nil[A])
    List.singleton(f(x)) = List.cons(f(x), List.nil[A])
    product_singleton(f(x))
}
