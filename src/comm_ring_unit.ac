from comm_ring import CommRing
from field import Field

/// True if `a` is a unit in the commutative ring `R`: there exists `b` with `a * b = R.1`.
define is_unit[R: CommRing](a: R) -> Bool {
    exists(b: R) { a * b = R.1 }
}

/// The multiplicative identity is a unit.
theorem is_unit_one[R: CommRing] {
    is_unit(R.1)
} by {
    R.1 * R.1 = R.1
    exists(b: R) { R.1 * b = R.1 }
}

/// `is_unit(a)` unfolds to the existence of a multiplicative right-inverse.
theorem is_unit_exists[R: CommRing](a: R) {
    is_unit(a) implies exists(b: R) { a * b = R.1 }
}

/// A witness for `a * b = R.1` exhibits `a` as a unit.
theorem is_unit_witness[R: CommRing](a: R, b: R) {
    a * b = R.1 implies is_unit(a)
} by {
    if a * b = R.1 {
        exists(c: R) { a * c = R.1 }
    }
}

/// In a commutative ring, units are symmetric in the witnessing equation.
theorem is_unit_symm[R: CommRing](a: R, b: R) {
    a * b = R.1 implies b * a = R.1
} by {
    if a * b = R.1 {
        b * a = a * b
    }
}

/// The product of two units is a unit.
theorem is_unit_mul[R: CommRing](a: R, b: R) {
    is_unit(a) and is_unit(b) implies is_unit(a * b)
} by {
    if is_unit(a) and is_unit(b) {
        is_unit_exists(a)
        is_unit_exists(b)
        let a_inv: R satisfy { a * a_inv = R.1 }
        let b_inv: R satisfy { b * b_inv = R.1 }
        let c: R = a_inv * b_inv
        (a * b) * c = (a * b) * (a_inv * b_inv)
        (a * b) * (a_inv * b_inv) = a * (b * (a_inv * b_inv))
        b * (a_inv * b_inv) = (b * a_inv) * b_inv
        (b * a_inv) * b_inv = (a_inv * b) * b_inv
        (a_inv * b) * b_inv = a_inv * (b * b_inv)
        a_inv * (b * b_inv) = a_inv * R.1
        a_inv * R.1 = a_inv
        b * (a_inv * b_inv) = a_inv
        a * (b * (a_inv * b_inv)) = a * a_inv
        a * a_inv = R.1
        (a * b) * c = R.1
        exists(d: R) { (a * b) * d = R.1 }
    }
}

/// The set of non-units of a commutative ring, as a membership predicate.
define non_units[R: CommRing](a: R) -> Bool {
    not is_unit(a)
}

/// The zero element is a non-unit unless `R.0 = R.1` (a trivial ring).
theorem zero_non_unit_or_trivial[R: CommRing] {
    non_units(R.0) or R.0 = R.1
} by {
    if R.0 != R.1 {
        if is_unit(R.0) {
            let b: R satisfy { R.0 * b = R.1 }
            R.0 * b = R.0
            R.0 = R.1
            false
        }
        not is_unit(R.0)
        non_units(R.0)
    }
}

/// In a field, every nonzero element is a unit.
theorem field_nonzero_is_unit[F: Field](a: F) {
    a != F.0 implies is_unit(a)
} by {
    if a != F.0 {
        a * a.inverse = F.1
        is_unit_witness(a, a.inverse)
    }
}

/// In a field, a non-unit is exactly the zero element.
theorem field_non_unit_iff_zero[F: Field](a: F) {
    non_units(a) = (a = F.0)
} by {
    if a = F.0 {
        if is_unit(a) {
            let b: F satisfy { a * b = F.1 }
            a * b = F.0
            F.0 = F.1
            false
        }
        not is_unit(a)
        non_units(a)
    }
    if non_units(a) {
        if a != F.0 {
            field_nonzero_is_unit(a)
            is_unit(a)
            false
        }
        a = F.0
    }
}
