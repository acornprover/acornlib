theorem pair_meet_assoc_rev_first[A: MeetSemilattice, B: MeetSemilattice](p: Pair[A, B], q: Pair[A, B], r: Pair[A, B]) {
    pair_meet(p, pair_meet(q, r)).first = p.first.meet(q.first.meet(r.first))
} by {
