from finite_group.base import FiniteGroup, FiniteSubgroup
from finite_group.coset_representatives import finite_left_coset_representatives,
    finite_left_coset_representatives_is_unique,
    finite_left_coset_representatives_cover_universal,
    finite_left_coset_representative_cardinality_is_order,
    finite_left_coset_representatives_distinct_disjoint
from list import List
from nat import Nat
from nat.nat_base import divides_mul, divides_self
from set import Set, list_set, list_set_contains_eq, unique_list_set_cardinality_is_length,
    set_eq_universal_of_forall_contains, cardinality_is_well_defined, list_indexed_union
from set_list_partition import set_list_all_cardinality_is, set_list_pairwise_disjoint,
    list_indexed_union_self_cardinality_is_of_unique_pairwise

/// The universal set of a finite group has cardinality equal to the group order.
theorem finite_group_universal_set_cardinality_is_order[G: FiniteGroup] {
    Set[G].universal_set.cardinality_is(G.order)
} by {
    forall(x: G) {
        G.elements.contains_every
        G.elements.contains(x)
        list_set_contains_eq[G](G.elements, x)
        list_set[G](G.elements).contains(x)
    }
    set_eq_universal_of_forall_contains[G](list_set[G](G.elements))
    list_set[G](G.elements) = Set[G].universal_set
    G.elements.is_unique
    unique_list_set_cardinality_is_length[G](G.elements)
    list_set[G](G.elements).cardinality_is(G.elements.length)
    G.order = G.elements.length
    Set[G].universal_set.cardinality_is(G.order)
}

/// The left-coset representative list has common cardinality equal to the subgroup order.
theorem finite_left_coset_representatives_all_cardinality_is_order[G: FiniteGroup](s: FiniteSubgroup[G]) {
    set_list_all_cardinality_is[G](finite_left_coset_representatives[G](s), s.order)
} by {
    let reps: List[Set[G]] = finite_left_coset_representatives[G](s)
    forall(c: Set[G]) {
        if reps.contains(c) {
            finite_left_coset_representative_cardinality_is_order[G](s, c)
            c.cardinality_is(s.order)
        }
        reps.contains(c) implies c.cardinality_is(s.order)
    }
    forall(c: Set[G]) { reps.contains(c) implies c.cardinality_is(s.order) }
    set_list_all_cardinality_is[G](reps, s.order) = forall(c: Set[G]) {
        reps.contains(c) implies c.cardinality_is(s.order)
    }
    set_list_all_cardinality_is[G](reps, s.order)
    set_list_all_cardinality_is[G](finite_left_coset_representatives[G](s), s.order)
}

lemma set_list_pairwise_disjoint_intro[K](items: List[Set[K]]) {
    (forall(c: Set[K], d: Set[K]) {
        items.contains(c) and items.contains(d) and c != d implies c.is_disjoint(d)
    }) implies set_list_pairwise_disjoint[K](items)
} by {
    if forall(c: Set[K], d: Set[K]) {
        items.contains(c) and items.contains(d) and c != d implies c.is_disjoint(d)
    } {
        forall(c: Set[K], d: Set[K]) {
            if items.contains(c) and items.contains(d) and c != d {
                c.is_disjoint(d)
            }
            items.contains(c) and items.contains(d) and c != d implies c.is_disjoint(d)
        }
        set_list_pairwise_disjoint[K](items) = forall(c: Set[K], d: Set[K]) {
            items.contains(c) and items.contains(d) and c != d implies c.is_disjoint(d)
        }
        set_list_pairwise_disjoint[K](items)
    }
}

lemma finite_left_coset_representatives_pairwise_disjoint_at[G: FiniteGroup](s: FiniteSubgroup[G], c: Set[G], d: Set[G]) {
    finite_left_coset_representatives[G](s).contains(c) and
    finite_left_coset_representatives[G](s).contains(d) and c != d implies c.is_disjoint(d)
} by {
    finite_left_coset_representatives_distinct_disjoint[G](s, c, d)
}

/// The left-coset representative list is pairwise disjoint.
theorem finite_left_coset_representatives_pairwise_disjoint[G: FiniteGroup](s: FiniteSubgroup[G]) {
    set_list_pairwise_disjoint[G](finite_left_coset_representatives[G](s))
} by {
    let reps: List[Set[G]] = finite_left_coset_representatives[G](s)
    forall(c: Set[G], d: Set[G]) {
        finite_left_coset_representatives_pairwise_disjoint_at[G](s, c, d)
        reps.contains(c) and reps.contains(d) and c != d implies c.is_disjoint(d)
    }
    set_list_pairwise_disjoint_intro[G](reps)
    set_list_pairwise_disjoint[G](reps)
    set_list_pairwise_disjoint[G](finite_left_coset_representatives[G](s))
}

/// The list-indexed union of all representative left cosets has cardinality `s.order * reps.length`.
theorem finite_left_coset_representatives_union_cardinality_is_order_product[G: FiniteGroup](s: FiniteSubgroup[G]) {
    list_indexed_union[G, Set[G]](
        finite_left_coset_representatives[G](s),
        function(c: Set[G]) { c }
    ).cardinality_is(s.order * finite_left_coset_representatives[G](s).length)
} by {
    finite_left_coset_representatives_is_unique[G](s)
    finite_left_coset_representatives_pairwise_disjoint[G](s)
    finite_left_coset_representatives_all_cardinality_is_order[G](s)
    list_indexed_union_self_cardinality_is_of_unique_pairwise[G](finite_left_coset_representatives[G](s), s.order)
}

/// The order of a finite group is the subgroup order times the number of left cosets.
theorem finite_subgroup_order_product_eq_group_order[G: FiniteGroup](s: FiniteSubgroup[G]) {
    s.order * finite_left_coset_representatives[G](s).length = G.order
} by {
    let reps: List[Set[G]] = finite_left_coset_representatives[G](s)
    let union: Set[G] = list_indexed_union[G, Set[G]](reps, function(c: Set[G]) { c })
    let n1: Nat = s.order * reps.length
    let n2: Nat = G.order
    finite_left_coset_representatives_union_cardinality_is_order_product[G](s)
    finite_left_coset_representatives_cover_universal[G](s)
    finite_group_universal_set_cardinality_is_order[G]
    union.cardinality_is(n1)
    union = Set[G].universal_set
    union.cardinality_is(n2)
    cardinality_is_well_defined[G](union, n1, n2)
}

/// The order of a finite subgroup divides the order of its finite group.
theorem finite_subgroup_order_divides_group_order[G: FiniteGroup](s: FiniteSubgroup[G]) {
    s.order.divides(G.order)
} by {
    let reps_len: Nat = finite_left_coset_representatives[G](s).length
    divides_self(s.order)
    divides_mul(s.order, s.order, reps_len)
    finite_subgroup_order_product_eq_group_order[G](s)
}
