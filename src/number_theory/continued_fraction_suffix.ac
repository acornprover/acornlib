        Nat.0 < continued_fraction_suffix_convergent(cf.coefficients, n).second
        continued_fraction_suffix_convergent_eq_coefficients_suffix_convergent(
            cf, n)
        Nat.0 < cf.suffix_convergent(n).second
    }
}

