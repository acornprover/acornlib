            List.cons(head, tail) {
                positive_continued_fraction_tail(List.cons(head, tail))
                continued_fraction_numerator_cons_positive_of_positive_tail(head, tail)
                Nat.0 < continued_fraction_numerator(List.cons(head, tail))
