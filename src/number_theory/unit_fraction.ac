}

/// A canonical ceiling denominator is positive.
theorem unit_fraction_ceiling_step_denominator_positive(q: Rat, n: Nat) {
    unit_fraction_ceiling_step(q, n) implies Nat.0 < n
} by {
    if unit_fraction_ceiling_step(q, n) {
