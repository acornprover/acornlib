            unit_fraction(n) * (Rat.from_int(q.denom) * Rat.from_nat(n))
        unit_fraction(n) * (Rat.from_int(q.denom) * Rat.from_nat(n)) =
            unit_fraction(n) * (Rat.from_nat(n) * Rat.from_int(q.denom))
        unit_fraction(n) * (Rat.from_nat(n) * Rat.from_int(q.denom)) =
