from nat.nat_base import Nat, alt_induction
from rat import Rat
from list import partial
from order import lte_antisymm, lte_trans, lt_of_lt_of_lte,
    not_lt_imp_gte, not_lte_imp_gt
from nat.semiring import from_nat, from_nat_add
from set import Set
from witness import choose_or_default, choose_or_default_spec,
    choose_or_default_unique_eq, exists_unique, exists_unique_intro
from real.exp import Real, exp, exp_add, exp_term, exp_term_partial_converges,
    div_lt_div_pos, exp_unbounded, exp_zero, exp_pos, exp_increasing,
    factorial_pos
from real.harmonic import rat_from_nat_lte_of_nat_lte, real_inverse_antitone_pos_strict,
    real_one_div_pos, real_recip_antitone_pos
from real.real_base import lt_add_converse
from real.real_field import mul_div_cancel
from real.real_ring import converges, limit
from real.real_seq import eps_lt_half
from real.real_series import geom_converges, geom_series_no_div, pow_nonneg,
    seq_lte, seq_lte_preserves_limit
from real.supremum import completeness, has_upper_bound, is_nonempty,
    is_set_supremum, is_set_upper_bound

numerals Real

/// True if `y` is a logarithm of `x` with respect to the real exponential.
define is_log(x: Real, y: Real) -> Bool {
    exp(y) = x
}

/// The logarithm value, defaulting to zero outside the positive real domain.
define log_or_zero(x: Real) -> Real {
    choose_or_default(is_log(x), Real.0)
}

/// The real logarithm, defined exactly on positive reals.
define log(x: Real) -> Option[Real] {
    if x > Real.0 {
        Option.some(log_or_zero(x))
    } else {
        Option.none[Real]
    }
}

/// True if `y` lies in the lower exponential preimage of `x`.
define exp_lower_preimage_contains(x: Real, y: Real) -> Bool {
    exp(y) <= x
}

/// The set of real `y` such that `exp(y) <= x`.
define exp_lower_preimage(x: Real) -> Set[Real] {
    Set[Real].new(exp_lower_preimage_contains(x))
}

/// Positive exponential values are nonzero.
theorem exp_ne_zero(x: Real) {
    exp(x) != Real.0
} by {
    exp_pos(x)
    exp(x) > Real.0
}

/// The exponential of a negated argument is the reciprocal exponential.
theorem exp_neg(x: Real) {
    exp(-x) = Real.1 / exp(x)
} by {
    exp_add(x, -x)
    x + -x = Real.0
    exp(Real.0) = exp(x) * exp(-x)
    exp_zero
    exp(Real.0) = Real.1
    exp(x) * exp(-x) = Real.1
    exp(x) != Real.0
    exp(-x) = Real.1 / exp(x)
}

/// Equal exponential values have equal arguments.
theorem exp_injective(x: Real, y: Real) {
    exp(x) = exp(y) implies x = y
} by {
    if exp(x) = exp(y) {
        if x < y {
            exp_increasing(x, y)
            exp(x) < exp(y)
            false
        }
        if y < x {
            exp_increasing(y, x)
            exp(y) < exp(x)
            false
        }
        x >= y
        y >= x
        lte_antisymm(x, y)
        x = y
    }
}

/// The exponential relation gives a unique logarithm.
theorem is_log_unique(x: Real, y: Real, z: Real) {
    is_log(x, y) and is_log(x, z) implies y = z
} by {
    if is_log(x, y) and is_log(x, z) {
        exp(y) = x
        exp(z) = x
        exp(y) = exp(z)
        exp_injective(y, z)
        y = z
    }
}

/// A real number in the image of the exponential has a unique logarithm.
theorem exists_unique_log_of_exp(x: Real) {
    exists_unique(is_log(exp(x)))
} by {
    is_log(exp(x), x)
    forall(y: Real) {
        if is_log(exp(x), y) {
            exp(y) = exp(x)
            exp_injective(y, x)
            y = x
        }
    }
    exists_unique_intro(is_log(exp(x)), x)
    exists_unique(is_log(exp(x)))
}

/// The logarithm is a left inverse to the exponential.
theorem log_exp(x: Real) {
    log(exp(x)) = Option.some(x)
} by {
    exp_pos(x)
    exp(x) > Real.0
    exists_unique_log_of_exp(x)
    is_log(exp(x), x)
    choose_or_default_unique_eq(is_log(exp(x)), Real.0, x)
    log_or_zero(exp(x)) = x
    log(exp(x)) = Option.some(log_or_zero(exp(x)))
    log(exp(x)) = Option.some(x)
}

/// The defaulting logarithm witness exponentiates back to `x` whenever an exponential preimage exists.
theorem exp_log_or_zero_of_exists(x: Real) {
    exists(y: Real) {
        exp(y) = x
    } implies exp(log_or_zero(x)) = x
} by {
    if exists(y: Real) { exp(y) = x } {
        exists(y: Real) {
            is_log(x, y)
        }
        choose_or_default_spec(is_log(x), Real.0)
        is_log(x, log_or_zero(x))
        exp(log_or_zero(x)) = x
    }
}

/// Exponential values are recovered by exponentiating their logarithm.
theorem exp_log_exp(x: Real) {
    log(exp(x)) = Option.some(x)
} by {
    log_exp(x)
}

/// The exponential of a natural multiple is the natural power of the exponential.
theorem exp_nat_mul(x: Real, n: Nat) {
    exp(from_nat[Real](n) * x) = exp(x).pow(n)
} by {
    define p(k: Nat) -> Bool {
        exp(from_nat[Real](k) * x) = exp(x).pow(k)
    }

    from_nat[Real](Nat.0) = Real.0
    Real.0 * x = Real.0
    exp(Real.0 * x) = exp(Real.0)
    exp_zero
    exp(Real.0) = Real.1
    exp(x).pow(Nat.0) = Real.1
    p(Nat.0)

    forall(k: Nat) {
        if p(k) {
            from_nat_add[Real](k, Nat.1)
            from_nat[Real](k + Nat.1) = from_nat[Real](k) + from_nat[Real](Nat.1)
            k + Nat.1 = k.suc
            from_nat[Real](Nat.1) = Real.1
            from_nat[Real](k.suc) = from_nat[Real](k) + Real.1
            from_nat[Real](k.suc) * x = (from_nat[Real](k) + Real.1) * x
            (from_nat[Real](k) + Real.1) * x = from_nat[Real](k) * x + x
            exp(from_nat[Real](k.suc) * x) = exp(from_nat[Real](k) * x + x)
            exp_add(from_nat[Real](k) * x, x)
            exp(from_nat[Real](k) * x + x) = exp(from_nat[Real](k) * x) * exp(x)
            exp(from_nat[Real](k) * x) = exp(x).pow(k)
            exp(from_nat[Real](k.suc) * x) = exp(x).pow(k) * exp(x)
            exp(x).pow(k.suc) = exp(x) * exp(x).pow(k)
            exp(x).pow(k) * exp(x) = exp(x) * exp(x).pow(k)
            exp(from_nat[Real](k.suc) * x) = exp(x).pow(k.suc)
            p(k.suc)
        }
    }

    alt_induction(p)
    forall(k: Nat) { p(k) }
    p(n)
}

/// Each nonnegative exponential-series term is bounded by the matching geometric term.
theorem exp_term_le_pow_of_nonneg(x: Real, n: Nat) {
    Real.0 <= x implies exp_term(x, n) <= x.pow(n)
} by {
    if Real.0 <= x {
        let denom = Real.from_rat(Rat.from_nat(n.factorial))
        factorial_pos(n)
        denom > Real.0
        Nat.1 <= n.factorial
        rat_from_nat_lte_of_nat_lte(Nat.1, n.factorial)
        Rat.1 <= Rat.from_nat(n.factorial)
        Real.from_rat(Rat.1) <= Real.from_rat(Rat.from_nat(n.factorial))
        Real.from_rat(Rat.1) = Real.1
        denom >= Real.1
        pow_nonneg(x, n)
        Real.0 <= x.pow(n)
        exp_term(x, n) = x.pow(n) / denom
        Real.1 > Real.0
        real_recip_antitone_pos(Real.1, denom)
        Real.1 / denom <= Real.1 / Real.1
        Real.1 / Real.1 = Real.1
        Real.1 / denom <= Real.1
        x.pow(n) * (Real.1 / denom) <= x.pow(n) * Real.1
        x.pow(n) / denom = x.pow(n) * (Real.1 / denom)
        x.pow(n) * Real.1 = x.pow(n)
        x.pow(n) / denom <= x.pow(n)
        exp_term(x, n) <= x.pow(n)
    }
}

/// For `0 <= x < 1`, the exponential is bounded by the geometric series.
theorem exp_le_geometric_limit(x: Real) {
    Real.0 <= x and x < Real.1 implies exp(x) <= limit(partial(x.pow))
} by {
    if Real.0 <= x and x < Real.1 {
        forall(n: Nat) {
            exp_term_le_pow_of_nonneg(x, n)
            exp_term(x, n) <= x.pow(n)
        }
        seq_lte(exp_term(x), x.pow)
        exp_term_partial_converges(x)
        converges(partial(exp_term(x)))
        x.abs = x
        x.abs < Real.1
        geom_converges(x)
        converges(partial(x.pow))
        seq_lte_preserves_limit(exp_term(x), x.pow)
        limit(partial(exp_term(x))) <= limit(partial(x.pow))
        exp(x) = limit(partial(exp_term(x)))
        exp(x) <= limit(partial(x.pow))
    }
}

/// The nonnegative geometric series has sum `1 / (1 - x)` for `x < 1`.
theorem geometric_limit_eq_recip(x: Real) {
    Real.0 <= x and x < Real.1 implies limit(partial(x.pow)) = Real.1 / (Real.1 - x)
} by {
    if Real.0 <= x and x < Real.1 {
        x.abs = x
        x.abs < Real.1
        geom_series_no_div(x)
        let geom = limit(partial(x.pow))
        Real.1 + x * geom = geom
        geom - x * geom = Real.1
        (Real.1 - x) * geom = Real.1
        Real.1 - x > Real.0
        Real.1 - x != Real.0
        geom = Real.1 / (Real.1 - x)
        limit(partial(x.pow)) = Real.1 / (Real.1 - x)
    }
}

/// The exponential is bounded by the closed-form geometric estimate.
theorem exp_le_geometric_recip(x: Real) {
    Real.0 <= x and x < Real.1 implies exp(x) <= Real.1 / (Real.1 - x)
} by {
    if Real.0 <= x and x < Real.1 {
        exp_le_geometric_limit(x)
        geometric_limit_eq_recip(x)
        exp(x) <= limit(partial(x.pow))
        limit(partial(x.pow)) = Real.1 / (Real.1 - x)
        exp(x) <= Real.1 / (Real.1 - x)
    }
}

/// Exponential values can be made arbitrarily close to `1` from above.
theorem exists_small_exp_below(r: Real) {
    r > Real.1 implies exists(d: Real) {
        d > Real.0 and exp(d) < r
    }
} by {
    if r > Real.1 {
        Real.1 > Real.0
        Real.0 < Real.1
        Real.1 < r
        Real.0 < r
        r > Real.0
        r != Real.0
        div_lt_div_pos(Real.1, r, r)
        Real.1 / r < r / r
        r / r = Real.1
        Real.1 / r < Real.1
        real_one_div_pos(r)
        Real.1 / r > Real.0
        let gap = Real.1 - Real.1 / r
        gap > Real.0
        eps_lt_half(gap)
        let d: Real satisfy {
            d.is_positive and d + d < gap
        }
        d > Real.0
        d + d < gap
        d < d + d
        d < gap
        gap = Real.1 - Real.1 / r
        Real.1 - Real.1 / r < Real.1 - Real.0
        Real.1 - Real.0 = Real.1
        Real.1 - Real.1 / r < Real.1
        gap < Real.1
        d < Real.1
        Real.0 <= d
        exp_le_geometric_recip(d)
        exp(d) <= Real.1 / (Real.1 - d)
        d < Real.1 - Real.1 / r
        d + Real.1 / r < (Real.1 - Real.1 / r) + Real.1 / r
        (Real.1 - Real.1 / r) + Real.1 / r = Real.1
        d + Real.1 / r < Real.1
        Real.1 / r + d = d + Real.1 / r
        (Real.1 - d) + d = Real.1
        Real.1 / r + d < (Real.1 - d) + d
        lt_add_converse(Real.1 / r, Real.1 - d, d)
        Real.1 / r < Real.1 - d
        Real.1 / r > Real.0
        Real.1 - d > Real.0
        real_inverse_antitone_pos_strict(Real.1 / r, Real.1 - d)
        (Real.1 - d).inverse < (Real.1 / r).inverse
        Real.1 / (Real.1 - d) = (Real.1 - d).inverse
        (Real.1 / r).inverse = r
        Real.1 / (Real.1 - d) < r
        if not exp(d) < r {
            exp(d) >= r
            r <= exp(d)
            Real.1 / (Real.1 - d) < r
            exp(d) <= Real.1 / (Real.1 - d)
            lte_trans(r, exp(d), Real.1 / (Real.1 - d))
            r <= Real.1 / (Real.1 - d)
            false
        }
        exp(d) < r
        exists(witness: Real) {
            witness = d and witness > Real.0 and exp(witness) < r
        }
    }
}

/// The lower exponential preimage of a positive real number is nonempty.
theorem exp_lower_preimage_nonempty(x: Real) {
    x > Real.0 implies is_nonempty(exp_lower_preimage(x))
} by {
    if x > Real.0 {
        if x >= Real.1 {
            exp_zero
            exp(Real.0) = Real.1
            exp(Real.0) <= x
            exp_lower_preimage(x).contains(Real.0)
            is_nonempty(exp_lower_preimage(x))
        } else {
            x < Real.1
            real_one_div_pos(x)
            Real.1 / x > Real.0
            exp_unbounded(Real.1 / x)
            let b: Real satisfy {
                Real.1 / x < exp(b)
            }
            exp_pos(b)
            exp(b) > Real.0
            real_inverse_antitone_pos_strict(Real.1 / x, exp(b))
            exp(b).inverse < (Real.1 / x).inverse
            exp_neg(b)
            exp(-b) = Real.1 / exp(b)
            Real.1 / exp(b) = exp(b).inverse
            (Real.1 / x).inverse = x
            exp(-b) < x
            exp(-b) <= x
            exp_lower_preimage(x).contains(-b)
            is_nonempty(exp_lower_preimage(x))
        }
    }
}

/// The lower exponential preimage of a positive real number is bounded above.
theorem exp_lower_preimage_has_upper_bound(x: Real) {
    x > Real.0 implies has_upper_bound(exp_lower_preimage(x))
} by {
    if x > Real.0 {
        exp_unbounded(x)
        let b: Real satisfy {
            x < exp(b)
        }
        forall(y: Real) {
            if exp_lower_preimage(x).contains(y) {
                exp(y) <= x
                if b < y {
                    exp_increasing(b, y)
                    exp(b) < exp(y)
                    exp(b) <= x
                    false
                }
                y <= b
            }
        }
        is_set_upper_bound(exp_lower_preimage(x), b)
        has_upper_bound(exp_lower_preimage(x))
    }
}

/// Every positive real number is an exponential value.
theorem exists_log_of_pos(x: Real) {
    x > Real.0 implies exists(y: Real) {
        exp(y) = x
    }
} by {
    if x > Real.0 {
        let s = exp_lower_preimage(x)
        exp_lower_preimage_nonempty(x)
        is_nonempty(s)
        exp_lower_preimage_has_upper_bound(x)
        has_upper_bound(s)
        completeness(s)
        let y: Real satisfy {
            is_set_supremum(s, y)
        }
        is_set_supremum(s, y)
        is_set_upper_bound(s, y)

        if exp(y) < x {
            exp_pos(y)
            exp(y) > Real.0
            let ratio = x / exp(y)
            div_lt_div_pos(exp(y), x, exp(y))
            exp(y) / exp(y) < x / exp(y)
            exp(y) / exp(y) = Real.1
            ratio > Real.1
            exists_small_exp_below(ratio)
            let d: Real satisfy {
                d > Real.0 and exp(d) < ratio
            }
            d > Real.0
            exp(d) < ratio
            exp(y) * exp(d) < exp(y) * ratio
            exp(y) * ratio = exp(y) * (x / exp(y))
            mul_div_cancel(x, exp(y))
            exp(y) * (x / exp(y)) = x
            exp(y) * exp(d) < x
            exp_add(y, d)
            exp(y + d) = exp(y) * exp(d)
            exp(y + d) < x
            exp(y + d) <= x
            exp_lower_preimage_contains(x, y + d)
            exp_lower_preimage(x).contains(y + d)
            s.contains(y + d)
            is_set_upper_bound(s, y) = forall(z: Real) {
                s.contains(z) implies z <= y
            }
            y + d <= y
            y < y + d
            false
        }

        if x < exp(y) {
            exp_pos(y)
            exp(y) > Real.0
            let ratio = exp(y) / x
            div_lt_div_pos(x, exp(y), x)
            x / x < exp(y) / x
            x / x = Real.1
            ratio > Real.1
            exists_small_exp_below(ratio)
            let d: Real satisfy {
                d > Real.0 and exp(d) < ratio
            }
            d > Real.0
            exp(d) < ratio
            exp_pos(d)
            exp(d) > Real.0
            x * exp(d) < x * ratio
            x * ratio = x * (exp(y) / x)
            mul_div_cancel(exp(y), x)
            x * (exp(y) / x) = exp(y)
            x * exp(d) < exp(y)
            exp_add(y - d, d)
            y - d + d = y
            exp(y) = exp(y - d) * exp(d)
            if not x < exp(y - d) {
                not_lt_imp_gte(x, exp(y - d))
                x >= exp(y - d)
                if not exp(y - d) <= x {
                    not_lte_imp_gt(exp(y - d), x)
                    exp(y - d) > x
                    x < exp(y - d)
                    false
                }
                exp(y - d) <= x
                exp(y - d) * exp(d) <= x * exp(d)
                exp(y) <= x * exp(d)
                false
            }
            x < exp(y - d)
            forall(z: Real) {
                if s.contains(z) {
                    exp(z) <= x
                    if y - d < z {
                        exp_increasing(y - d, z)
                        exp(y - d) < exp(z)
                        lt_of_lt_of_lte(exp(y - d), exp(z), x)
                        exp(y - d) < x
                        false
                    }
                    z <= y - d
                }
            }
            is_set_upper_bound(s, y - d)
            is_set_supremum(s, y) = is_set_upper_bound(s, y) and forall(b: Real) {
                is_set_upper_bound(s, b) implies y <= b
            }
            y <= y - d
            y - d + d = y
            y - d < y - d + d
            y - d < y
            false
        }

        exp(y) >= x
        exp(y) <= x
        lte_antisymm(exp(y), x)
        exp(y) = x
        exists(witness: Real) {
            witness = y and exp(witness) = x
        }
    }
}

/// Positive inputs have a logarithm value.
theorem log_some_of_pos(x: Real) {
    x > Real.0 implies log(x) = Option.some(log_or_zero(x))
} by {
    if x > Real.0 {
        log(x) = Option.some(log_or_zero(x))
    }
}

/// Nonpositive inputs have no logarithm value.
theorem log_none_of_nonpos(x: Real) {
    not x > Real.0 implies log(x) = Option.none[Real]
} by {
    if not x > Real.0 {
        log(x) = Option.none[Real]
    }
}

/// The defaulting logarithm witness is a right inverse to the exponential on positive reals.
theorem exp_log_or_zero(x: Real) {
    x > Real.0 implies exp(log_or_zero(x)) = x
} by {
    if x > Real.0 {
        exists_log_of_pos(x)
        exp_log_or_zero_of_exists(x)
        exp(log_or_zero(x)) = x
    }
}

/// The logarithm of one is zero.
theorem log_one {
    log(Real.1) = Option.some(Real.0)
} by {
    exp_zero
    exp(Real.0) = Real.1
    log_exp(Real.0)
    log(exp(Real.0)) = Option.some(Real.0)
    log(Real.1) = Option.some(Real.0)
}

/// The logarithm of a positive product is the sum of the logarithms.
theorem log_mul(x: Real, y: Real) {
    x > Real.0 and y > Real.0 implies log(x * y) = Option.some(log_or_zero(x) + log_or_zero(y))
} by {
    if x > Real.0 and y > Real.0 {
        x.is_positive
        y.is_positive
        (x * y).is_positive
        x * y > Real.0
        exp_log_or_zero(x)
        exp_log_or_zero(y)
        exp_log_or_zero(x * y)
        exp(log_or_zero(x)) = x
        exp(log_or_zero(y)) = y
        exp(log_or_zero(x * y)) = x * y
        exp_add(log_or_zero(x), log_or_zero(y))
        exp(log_or_zero(x) + log_or_zero(y)) = exp(log_or_zero(x)) * exp(log_or_zero(y))
        exp(log_or_zero(x) + log_or_zero(y)) = x * y
        exp(log_or_zero(x * y)) = exp(log_or_zero(x) + log_or_zero(y))
        exp_injective(log_or_zero(x * y), log_or_zero(x) + log_or_zero(y))
        log_or_zero(x * y) = log_or_zero(x) + log_or_zero(y)
        log_some_of_pos(x * y)
        log(x * y) = Option.some(log_or_zero(x * y))
        log(x * y) = Option.some(log_or_zero(x) + log_or_zero(y))
    }
}

/// Real exponentiation where it is defined over the reals.
/// Positive bases use `exp(exponent * base.log_or_zero)`; `0^0 = 1`; and `0^x = 0` for positive `x`.
define rpow(base: Real, exponent: Real) -> Option[Real] {
    if base > Real.0 {
        Option.some(exp(exponent * log_or_zero(base)))
    } else {
        if base = Real.0 {
            if exponent = Real.0 {
                Option.some(Real.1)
            } else {
                if exponent > Real.0 {
                    Option.some(Real.0)
                } else {
                    Option.none[Real]
                }
            }
        } else {
            Option.none[Real]
        }
    }
}

/// Real powers with positive base are positive.
theorem rpow_pos(base: Real, exponent: Real) {
    base > Real.0 implies exists(value: Real) {
        rpow(base, exponent) = Option.some(value) and value > Real.0
    }
} by {
    if base > Real.0 {
        rpow(base, exponent) = Option.some(exp(exponent * log_or_zero(base)))
        exp_pos(exponent * log_or_zero(base))
        exp(exponent * log_or_zero(base)) > Real.0
        exists(value: Real) {
            value = exp(exponent * log_or_zero(base)) and
            rpow(base, exponent) = Option.some(value) and value > Real.0
        }
    }
}

/// The zeroth real power of a nonnegative base is one.
theorem rpow_zero(base: Real) {
    base >= Real.0 implies rpow(base, Real.0) = Option.some(Real.1)
} by {
    if base > Real.0 {
        rpow(base, Real.0) = Option.some(exp(Real.0 * log_or_zero(base)))
        Real.0 * log_or_zero(base) = Real.0
        exp_zero
        exp(Real.0) = Real.1
        rpow(base, Real.0) = Option.some(Real.1)
    } else {
        base = Real.0
        rpow(base, Real.0) = Option.some(Real.1)
    }
}

/// Negative bases are outside the real-power domain used here.
theorem rpow_neg_base(base: Real, exponent: Real) {
    base < Real.0 implies rpow(base, exponent) = Option.none[Real]
} by {
    if base < Real.0 {
        not base > Real.0
        base != Real.0
        rpow(base, exponent) = Option.none[Real]
    }
}

/// Zero to a positive exponent is zero.
theorem rpow_zero_base_pos(exponent: Real) {
    exponent > Real.0 implies rpow(Real.0, exponent) = Option.some(Real.0)
} by {
    if exponent > Real.0 {
        not Real.0 > Real.0
        exponent != Real.0
        rpow(Real.0, exponent) = Option.some(Real.0)
    }
}

/// Zero to the zeroth power is one.
theorem rpow_zero_zero {
    rpow(Real.0, Real.0) = Option.some(Real.1)
} by {
    not Real.0 > Real.0
    rpow(Real.0, Real.0) = Option.some(Real.1)
}

/// The first real power of a positive base is the base.
theorem rpow_one(base: Real) {
    base > Real.0 implies rpow(base, Real.1) = Option.some(base)
} by {
    if base > Real.0 {
        rpow(base, Real.1) = Option.some(exp(Real.1 * log_or_zero(base)))
        Real.1 * log_or_zero(base) = log_or_zero(base)
        exp_log_or_zero(base)
        exp(log_or_zero(base)) = base
        rpow(base, Real.1) = Option.some(base)
    }
}

/// Real powers of a fixed positive base turn addition into multiplication.
theorem rpow_add(base: Real, a: Real, b: Real) {
    base > Real.0 implies rpow(base, a + b) = Option.some(exp(a * log_or_zero(base)) * exp(b * log_or_zero(base)))
} by {
    if base > Real.0 {
        rpow(base, a + b) = Option.some(exp((a + b) * log_or_zero(base)))
        (a + b) * log_or_zero(base) = a * log_or_zero(base) + b * log_or_zero(base)
        exp_add(a * log_or_zero(base), b * log_or_zero(base))
        exp(a * log_or_zero(base) + b * log_or_zero(base)) = exp(a * log_or_zero(base)) * exp(b * log_or_zero(base))
        rpow(base, a + b) = Option.some(exp(a * log_or_zero(base)) * exp(b * log_or_zero(base)))
    }
}

/// The logarithm of a positive-base real power is the exponent times the base logarithm.
theorem log_rpow(base: Real, exponent: Real) {
    base > Real.0 implies log(exp(exponent * log_or_zero(base))) = Option.some(exponent * log_or_zero(base))
} by {
    if base > Real.0 {
        log_exp(exponent * log_or_zero(base))
        log(exp(exponent * log_or_zero(base))) = Option.some(exponent * log_or_zero(base))
    }
}

/// Real powers multiply exponents on positive bases.
theorem rpow_mul(base: Real, a: Real, b: Real) {
    base > Real.0 implies rpow(base, a * b) = Option.some(exp(b * (a * log_or_zero(base))))
} by {
    if base > Real.0 {
        rpow(base, a * b) = Option.some(exp((a * b) * log_or_zero(base)))
        b * (a * log_or_zero(base)) = (a * b) * log_or_zero(base)
        rpow(base, a * b) = Option.some(exp(b * (a * log_or_zero(base))))
    }
}

/// Natural real exponents agree with the ordinary natural power on exponential values.
theorem rpow_exp_nat(x: Real, n: Nat) {
    rpow(exp(x), from_nat[Real](n)) = Option.some(exp(x).pow(n))
} by {
    exp_pos(x)
    log_exp(x)
    rpow(exp(x), from_nat[Real](n)) = Option.some(exp(from_nat[Real](n) * log_or_zero(exp(x))))
    log(exp(x)) = Option.some(x)
    log(exp(x)) = Option.some(log_or_zero(exp(x)))
    Option.some(log_or_zero(exp(x))) = Option.some(x)
    some_injective[Real](log_or_zero(exp(x)), x)
    log_or_zero(exp(x)) = x
    exp(from_nat[Real](n) * log_or_zero(exp(x))) = exp(from_nat[Real](n) * x)
    exp_nat_mul(x, n)
    exp(from_nat[Real](n) * x) = exp(x).pow(n)
    rpow(exp(x), from_nat[Real](n)) = Option.some(exp(x).pow(n))
}

/// Natural real exponents agree with ordinary natural powers for positive bases.
theorem rpow_nat(base: Real, n: Nat) {
    base > Real.0 implies rpow(base, from_nat[Real](n)) = Option.some(base.pow(n))
} by {
    if base > Real.0 {
        exp_log_or_zero(base)
        exp(log_or_zero(base)) = base
        rpow(base, from_nat[Real](n)) = Option.some(exp(from_nat[Real](n) * log_or_zero(base)))
        exp_nat_mul(log_or_zero(base), n)
        exp(from_nat[Real](n) * log_or_zero(base)) = exp(log_or_zero(base)).pow(n)
        exp(log_or_zero(base)).pow(n) = base.pow(n)
        rpow(base, from_nat[Real](n)) = Option.some(base.pow(n))
    }
}

attributes Real {
    /// The real logarithm, defined exactly on positive reals.
    let log = log

    /// The logarithm value, defaulting to zero outside the positive real domain.
    let log_or_zero = log_or_zero

    /// Real exponentiation where it is defined over the reals.
    let rpow = rpow
}
