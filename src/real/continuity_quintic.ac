from function_algebra import pointwise_mul
from functions import identity_fn
from real.continuity_pointwise_mul import continuous_at_pointwise_mul,
    continuous_pointwise_mul
from real.continuity_composition import continuous_imp_continuous_at
from real.continuity_sequences import identity_function_is_continuous
from real.continuity_quartic import continuous_at_quartic_real,
    continuous_quartic_real, quartic_real
from real.default import Real, continuous, continuous_at

/// The pointwise fifth power of a real number.
define quintic_real(x: Real) -> Real {
    x * x * x * x * x
}

/// The quintic function agrees with the pointwise product of the quartic with the identity.
theorem quintic_real_eq_pointwise_mul_quartic_identity {
    quintic_real = pointwise_mul[Real, Real](quartic_real, identity_fn[Real])
} by {
    forall(x: Real) {
        identity_fn[Real](x) = x
        quartic_real(x) = x * x * x * x
        pointwise_mul[Real, Real](quartic_real, identity_fn[Real], x) = quartic_real(x) * identity_fn[Real](x)
        pointwise_mul[Real, Real](quartic_real, identity_fn[Real], x) = (x * x * x * x) * x
        quintic_real(x) = x * x * x * x * x
        quintic_real(x) = pointwise_mul[Real, Real](quartic_real, identity_fn[Real], x)
    }
}

/// The quintic function on the reals is continuous at each point.
theorem continuous_at_quintic_real(x: Real) {
    continuous_at(quintic_real, x)
} by {
    continuous_at_quartic_real(x)
    continuous_at(quartic_real, x)
    identity_function_is_continuous
    continuous_imp_continuous_at(identity_fn[Real], x)
    continuous_at(identity_fn[Real], x)
    continuous_at_pointwise_mul(quartic_real, identity_fn[Real], x)
    continuous_at(pointwise_mul[Real, Real](quartic_real, identity_fn[Real]), x)
    quintic_real_eq_pointwise_mul_quartic_identity
    continuous_at(quintic_real, x)
}

/// The quintic function on the reals is continuous.
theorem continuous_quintic_real {
    continuous(quintic_real)
} by {
    continuous_quartic_real
    continuous(quartic_real)
    identity_function_is_continuous
    continuous(identity_fn[Real])
    continuous_pointwise_mul(quartic_real, identity_fn[Real])
    continuous(pointwise_mul[Real, Real](quartic_real, identity_fn[Real]))
    quintic_real_eq_pointwise_mul_quartic_identity
    continuous(quintic_real)
}
