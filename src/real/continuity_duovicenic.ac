from function_algebra import pointwise_mul
from real.continuity_pointwise_mul import continuous_at_pointwise_mul,
    continuous_pointwise_mul
from real.continuity_undecic import continuous_at_undecic_real,
    continuous_undecic_real, undecic_real
from real.default import Real, continuous, continuous_at

/// The pointwise twenty-second power of a real number.
define duovicenic_real(x: Real) -> Real {
    undecic_real(x) * undecic_real(x)
}

/// The twenty-second power agrees with the pointwise product of the eleventh power with itself.
theorem duovicenic_real_eq_pointwise_mul_undecic_undecic {
    duovicenic_real = pointwise_mul[Real, Real](undecic_real, undecic_real)
} by {
    forall(x: Real) {
        pointwise_mul[Real, Real](undecic_real, undecic_real, x) = undecic_real(x) * undecic_real(x)
        duovicenic_real(x) = undecic_real(x) * undecic_real(x)
        duovicenic_real(x) = pointwise_mul[Real, Real](undecic_real, undecic_real, x)
    }
}

/// The twenty-second power function on the reals is continuous at each point.
theorem continuous_at_duovicenic_real(x: Real) {
    continuous_at(duovicenic_real, x)
} by {
    continuous_at_undecic_real(x)
    continuous_at(undecic_real, x)
    continuous_at_pointwise_mul(undecic_real, undecic_real, x)
    continuous_at(pointwise_mul[Real, Real](undecic_real, undecic_real), x)
    duovicenic_real_eq_pointwise_mul_undecic_undecic
    continuous_at(duovicenic_real, x)
}

/// The twenty-second power function on the reals is continuous.
theorem continuous_duovicenic_real {
    continuous(duovicenic_real)
} by {
    continuous_undecic_real
    continuous(undecic_real)
    continuous_pointwise_mul(undecic_real, undecic_real)
    continuous(pointwise_mul[Real, Real](undecic_real, undecic_real))
    duovicenic_real_eq_pointwise_mul_undecic_undecic
    continuous(duovicenic_real)
}
