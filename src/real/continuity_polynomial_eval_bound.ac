from nat import Nat
from order import closed_interval_set
from polynomial import Polynomial, polynomial_eval_bound
from real.continuity_composition import continuous_intro
from real.derivative_coeff_eval import polynomial_eval_bound_suc_differentiable_at
from real.derivative_continuity import differentiable_continuous_at
from real.default import Real, continuous, continuous_at
from real.intermediate_value_consequences import bolzano_closed_interval_negative_to_positive,
    bolzano_closed_interval_nonpositive_to_nonnegative

/// Bounded polynomial evaluation at a successor coefficient bound is continuous at every point.
theorem polynomial_eval_bound_suc_continuous_at(
    p: Polynomial[Real], n: Nat, x0: Real
) {
    continuous_at(function(x: Real) { polynomial_eval_bound(p, x, n.suc) }, x0)
} by {
    polynomial_eval_bound_suc_differentiable_at(p, n, x0)
    differentiable_continuous_at(function(x: Real) { polynomial_eval_bound(p, x, n.suc) }, x0)
    continuous_at(function(x: Real) { polynomial_eval_bound(p, x, n.suc) }, x0)
}

/// Bounded polynomial evaluation at a successor coefficient bound is continuous.
theorem polynomial_eval_bound_suc_continuous(p: Polynomial[Real], n: Nat) {
    continuous(function(x: Real) { polynomial_eval_bound(p, x, n.suc) })
} by {
    forall(x0: Real) {
        polynomial_eval_bound_suc_continuous_at(p, n, x0)
        continuous_at(function(x: Real) { polynomial_eval_bound(p, x, n.suc) }, x0)
    }
    continuous_intro(function(x: Real) { polynomial_eval_bound(p, x, n.suc) })
    continuous(function(x: Real) { polynomial_eval_bound(p, x, n.suc) })
}

/// A bounded polynomial evaluation changing from nonpositive to nonnegative has a zero.
theorem polynomial_eval_bound_suc_bolzano_nonpositive_to_nonnegative(
    p: Polynomial[Real], n: Nat, lower: Real, upper: Real
) {
    lower <= upper and
    polynomial_eval_bound(p, lower, n.suc) <= Real.0 and
    Real.0 <= polynomial_eval_bound(p, upper, n.suc)
    implies exists(root: Real) {
        closed_interval_set(lower, upper).contains(root) and
        polynomial_eval_bound(p, root, n.suc) = Real.0
    }
} by {
    if lower <= upper and
        polynomial_eval_bound(p, lower, n.suc) <= Real.0 and
        Real.0 <= polynomial_eval_bound(p, upper, n.suc) {
        lower <= upper
        polynomial_eval_bound(p, lower, n.suc) <= Real.0
        Real.0 <= polynomial_eval_bound(p, upper, n.suc)
        polynomial_eval_bound_suc_continuous(p, n)
        continuous(function(x: Real) { polynomial_eval_bound(p, x, n.suc) })
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) =
            polynomial_eval_bound(p, lower, n.suc)
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper) =
            polynomial_eval_bound(p, upper, n.suc)
        if not function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) <= Real.0 {
            polynomial_eval_bound(p, lower, n.suc) <= Real.0
            false
        }
        if not Real.0 <= function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper) {
            Real.0 <= polynomial_eval_bound(p, upper, n.suc)
            false
        }
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) <= Real.0
        Real.0 <= function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper)
        continuous(function(x: Real) { polynomial_eval_bound(p, x, n.suc) }) and
            lower <= upper and
            function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) <= Real.0 and
            Real.0 <= function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper)
        bolzano_closed_interval_nonpositive_to_nonnegative(
            function(x: Real) { polynomial_eval_bound(p, x, n.suc) },
            lower,
            upper
        )
        let root: Real satisfy {
            closed_interval_set(lower, upper).contains(root) and
            function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(root) = Real.0
        }
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(root) =
            polynomial_eval_bound(p, root, n.suc)
        polynomial_eval_bound(p, root, n.suc) = Real.0
        exists(point: Real) {
            closed_interval_set(lower, upper).contains(point) and
            polynomial_eval_bound(p, point, n.suc) = Real.0
        }
    }
}

/// A bounded polynomial evaluation changing from negative to positive has a zero.
theorem polynomial_eval_bound_suc_bolzano_negative_to_positive(
    p: Polynomial[Real], n: Nat, lower: Real, upper: Real
) {
    lower <= upper and
    polynomial_eval_bound(p, lower, n.suc) < Real.0 and
    Real.0 < polynomial_eval_bound(p, upper, n.suc)
    implies exists(root: Real) {
        closed_interval_set(lower, upper).contains(root) and
        polynomial_eval_bound(p, root, n.suc) = Real.0
    }
} by {
    if lower <= upper and
        polynomial_eval_bound(p, lower, n.suc) < Real.0 and
        Real.0 < polynomial_eval_bound(p, upper, n.suc) {
        lower <= upper
        polynomial_eval_bound(p, lower, n.suc) < Real.0
        Real.0 < polynomial_eval_bound(p, upper, n.suc)
        polynomial_eval_bound_suc_continuous(p, n)
        continuous(function(x: Real) { polynomial_eval_bound(p, x, n.suc) })
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) =
            polynomial_eval_bound(p, lower, n.suc)
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper) =
            polynomial_eval_bound(p, upper, n.suc)
        if not function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) < Real.0 {
            polynomial_eval_bound(p, lower, n.suc) < Real.0
            false
        }
        if not Real.0 < function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper) {
            Real.0 < polynomial_eval_bound(p, upper, n.suc)
            false
        }
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) < Real.0
        Real.0 < function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper)
        continuous(function(x: Real) { polynomial_eval_bound(p, x, n.suc) }) and
            lower <= upper and
            function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(lower) < Real.0 and
            Real.0 < function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(upper)
        bolzano_closed_interval_negative_to_positive(
            function(x: Real) { polynomial_eval_bound(p, x, n.suc) },
            lower,
            upper
        )
        let root: Real satisfy {
            closed_interval_set(lower, upper).contains(root) and
            function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(root) = Real.0
        }
        function(x: Real) { polynomial_eval_bound(p, x, n.suc) }(root) =
            polynomial_eval_bound(p, root, n.suc)
        polynomial_eval_bound(p, root, n.suc) = Real.0
        exists(point: Real) {
            closed_interval_set(lower, upper).contains(point) and
            polynomial_eval_bound(p, point, n.suc) = Real.0
        }
    }
}
