from function_algebra import pointwise_mul
from functions import compose, function_eq_transport_predicate_rev, function_extensionality,
    identity_fn
from nat.nat_base import Nat, alt_induction, add_one_right
from real.continuity_pointwise_pow import pointwise_pow
from real.continuity_pow import pow_real_fn
from real.derivative_basic import has_derivative_at, differentiable_at,
    identity_has_derivative_at
from real.derivative_chain import derivative_compose
from real.derivative_product import derivative_pointwise_mul
from real.real_base import Real
from real.real_ring import mul_one_left, mul_one_right
from semiring import from_nat, from_nat_add, from_nat_one

lemma pow_real_fn_one_apply(x: Real) {
    pow_real_fn(Nat.1, x) = x
} by {
    pow_real_fn(Nat.1, x) = x.pow(Nat.1)
    x.pow(Nat.1) = x * x.pow(Nat.0)
    x.pow(Nat.0) = Real.1
    x * x.pow(Nat.0) = x * Real.1
    mul_one_right(x)
    x * Real.1 = x
    pow_real_fn(Nat.1, x) = x
}

lemma pow_real_fn_one_eq_identity {
    pow_real_fn(Nat.1) = identity_fn[Real]
} by {
    forall(x: Real) {
        pow_real_fn_one_apply(x)
        pow_real_fn(Nat.1, x) = x
        identity_fn[Real](x) = x
        pow_real_fn(Nat.1, x) = identity_fn[Real](x)
    }
    function_extensionality(pow_real_fn(Nat.1), identity_fn[Real])
}

lemma from_nat_real_suc_eq_add_one(n: Nat) {
    from_nat[Real](n.suc) = from_nat[Real](n) + Real.1
} by {
    from_nat_add[Real](n, Nat.1)
    from_nat[Real](n + Nat.1) = from_nat[Real](n) + from_nat[Real](Nat.1)
    add_one_right(n)
    n + Nat.1 = n.suc
    from_nat_one[Real]
    from_nat[Real](Nat.1) = Real.1
    from_nat[Real](n.suc) = from_nat[Real](n) + Real.1
}

lemma pow_real_fn_suc_as_mul_one(n: Nat) {
    pow_real_fn(n.suc) = pointwise_mul[Real, Real](pow_real_fn(Nat.1), pow_real_fn(n))
} by {
    forall(x: Real) {
        pow_real_fn(n.suc, x) = x.pow(n.suc)
        x.pow(n.suc) = x * x.pow(n)
        pow_real_fn_one_apply(x)
        pow_real_fn(Nat.1, x) = x
        pow_real_fn(n, x) = x.pow(n)
        pointwise_mul[Real, Real](pow_real_fn(Nat.1), pow_real_fn(n), x) =
            pow_real_fn(Nat.1, x) * pow_real_fn(n, x)
        pointwise_mul[Real, Real](pow_real_fn(Nat.1), pow_real_fn(n), x) = x * x.pow(n)
        pow_real_fn(n.suc, x) = pointwise_mul[Real, Real](pow_real_fn(Nat.1), pow_real_fn(n), x)
    }
    function_extensionality(pow_real_fn(n.suc), pointwise_mul[Real, Real](pow_real_fn(Nat.1), pow_real_fn(n)))
}

lemma pointwise_pow_eq_compose_pow_real_fn(f: Real -> Real, n: Nat) {
    pointwise_pow(f, n) = compose(pow_real_fn(n), f)
} by {
    forall(x: Real) {
        pointwise_pow(f, n, x) = f(x).pow(n)
        compose(pow_real_fn(n), f, x) = pow_real_fn(n, f(x))
        pow_real_fn(n, f(x)) = f(x).pow(n)
        pointwise_pow(f, n, x) = compose(pow_real_fn(n), f, x)
    }
    function_extensionality(pointwise_pow(f, n), compose(pow_real_fn(n), f))
}

lemma power_derivative_step_simplifies(n: Nat, x0: Real) {
    pow_real_fn(Nat.1, x0) * (from_nat[Real](n.suc) * x0.pow(n)) + pow_real_fn(n.suc, x0) * Real.1 =
        from_nat[Real](n.suc.suc) * x0.pow(n.suc)
} by {
    pow_real_fn_one_apply(x0)
    pow_real_fn(Nat.1, x0) = x0
    pow_real_fn(n.suc, x0) = x0.pow(n.suc)
    x0.pow(n.suc) = x0 * x0.pow(n)
    mul_one_right(x0.pow(n.suc))
    x0.pow(n.suc) * Real.1 = x0.pow(n.suc)
    x0 * (from_nat[Real](n.suc) * x0.pow(n)) = from_nat[Real](n.suc) * (x0 * x0.pow(n))
    x0 * (from_nat[Real](n.suc) * x0.pow(n)) = from_nat[Real](n.suc) * x0.pow(n.suc)
    pow_real_fn(Nat.1, x0) * (from_nat[Real](n.suc) * x0.pow(n)) + pow_real_fn(n.suc, x0) * Real.1 =
        from_nat[Real](n.suc) * x0.pow(n.suc) + x0.pow(n.suc)
    mul_one_left(x0.pow(n.suc))
    Real.1 * x0.pow(n.suc) = x0.pow(n.suc)
    x0.pow(n.suc) = Real.1 * x0.pow(n.suc)
    from_nat[Real](n.suc) * x0.pow(n.suc) + x0.pow(n.suc) =
        from_nat[Real](n.suc) * x0.pow(n.suc) + Real.1 * x0.pow(n.suc)
    from_nat[Real](n.suc) * x0.pow(n.suc) + Real.1 * x0.pow(n.suc) =
        (from_nat[Real](n.suc) + Real.1) * x0.pow(n.suc)
    from_nat_real_suc_eq_add_one(n.suc)
    from_nat[Real](n.suc.suc) = from_nat[Real](n.suc) + Real.1
    (from_nat[Real](n.suc) + Real.1) * x0.pow(n.suc) = from_nat[Real](n.suc.suc) * x0.pow(n.suc)
    pow_real_fn(Nat.1, x0) * (from_nat[Real](n.suc) * x0.pow(n)) + pow_real_fn(n.suc, x0) * Real.1 =
        from_nat[Real](n.suc.suc) * x0.pow(n.suc)
}

/// The derivative of the positive natural power function `x ↦ x^(n+1)`.
theorem pow_real_fn_suc_has_derivative_at(n: Nat, x0: Real) {
    has_derivative_at(pow_real_fn(n.suc), x0, from_nat[Real](n.suc) * x0.pow(n))
} by {
    define p(k: Nat) -> Bool {
        has_derivative_at(pow_real_fn(k.suc), x0, from_nat[Real](k.suc) * x0.pow(k))
    }
    define derivative_pred(value: Real, h: Real -> Real) -> Bool {
        has_derivative_at(h, x0, value)
    }

    pow_real_fn_one_eq_identity
    identity_has_derivative_at(x0)
    has_derivative_at(pow_real_fn(Nat.1), x0, Real.1)
    from_nat_one[Real]
    from_nat[Real](Nat.1) = Real.1
    x0.pow(Nat.0) = Real.1
    from_nat[Real](Nat.1) * x0.pow(Nat.0) = Real.1 * Real.1
    mul_one_left(Real.1)
    Real.1 * Real.1 = Real.1
    has_derivative_at(pow_real_fn(Nat.1), x0, from_nat[Real](Nat.1) * x0.pow(Nat.0))
    Nat.0.suc = Nat.1
    has_derivative_at(pow_real_fn(Nat.0.suc), x0, from_nat[Real](Nat.0.suc) * x0.pow(Nat.0))
    p(Nat.0)

    forall(k: Nat) {
        if p(k) {
            has_derivative_at(pow_real_fn(Nat.1), x0, Real.1)
            has_derivative_at(pow_real_fn(k.suc), x0, from_nat[Real](k.suc) * x0.pow(k))
            derivative_pointwise_mul(
                pow_real_fn(Nat.1),
                pow_real_fn(k.suc),
                x0,
                Real.1,
                from_nat[Real](k.suc) * x0.pow(k)
            )
            has_derivative_at(
                pointwise_mul(pow_real_fn(Nat.1), pow_real_fn(k.suc)),
                x0,
                pow_real_fn(Nat.1, x0) * (from_nat[Real](k.suc) * x0.pow(k)) + pow_real_fn(k.suc, x0) * Real.1
            )
            power_derivative_step_simplifies(k, x0)
            pow_real_fn(Nat.1, x0) * (from_nat[Real](k.suc) * x0.pow(k)) + pow_real_fn(k.suc, x0) * Real.1 =
                from_nat[Real](k.suc.suc) * x0.pow(k.suc)
            has_derivative_at(
                pointwise_mul(pow_real_fn(Nat.1), pow_real_fn(k.suc)),
                x0,
                from_nat[Real](k.suc.suc) * x0.pow(k.suc)
            )
            pow_real_fn_suc_as_mul_one(k.suc)
            pow_real_fn(k.suc.suc) = pointwise_mul(pow_real_fn(Nat.1), pow_real_fn(k.suc))
            derivative_pred(
                from_nat[Real](k.suc.suc) * x0.pow(k.suc),
                pointwise_mul(pow_real_fn(Nat.1), pow_real_fn(k.suc))
            )
            function_eq_transport_predicate_rev(
                derivative_pred(from_nat[Real](k.suc.suc) * x0.pow(k.suc)),
                pow_real_fn(k.suc.suc),
                pointwise_mul(pow_real_fn(Nat.1), pow_real_fn(k.suc))
            )
            derivative_pred(from_nat[Real](k.suc.suc) * x0.pow(k.suc), pow_real_fn(k.suc.suc))
            has_derivative_at(pow_real_fn(k.suc.suc), x0, from_nat[Real](k.suc.suc) * x0.pow(k.suc))
            p(k.suc)
        }
    }

    p(Nat.0) and forall(k: Nat) { p(k) implies p(k.suc) }
    alt_induction(p)
    p(n)
}

/// Positive natural power functions are differentiable at every real point.
theorem pow_real_fn_suc_differentiable_at(n: Nat, x0: Real) {
    differentiable_at(pow_real_fn(n.suc), x0)
} by {
    pow_real_fn_suc_has_derivative_at(n, x0)
    exists(d: Real) {
        has_derivative_at(pow_real_fn(n.suc), x0, d)
    }
}

/// The derivative of a positive natural power of a differentiable real-valued function.
theorem derivative_pointwise_pow_suc(f: Real -> Real, n: Nat, x0: Real, d: Real) {
    has_derivative_at(f, x0, d) implies
    has_derivative_at(
        pointwise_pow(f, n.suc),
        x0,
        (from_nat[Real](n.suc) * f(x0).pow(n)) * d
    )
} by {
    define derivative_pred(value: Real, h: Real -> Real) -> Bool {
        has_derivative_at(h, x0, value)
    }
    pow_real_fn_suc_has_derivative_at(n, f(x0))
    derivative_compose(f, pow_real_fn(n.suc), x0, d, from_nat[Real](n.suc) * f(x0).pow(n))
    has_derivative_at(
        compose(pow_real_fn(n.suc), f),
        x0,
        (from_nat[Real](n.suc) * f(x0).pow(n)) * d
    )
    pointwise_pow_eq_compose_pow_real_fn(f, n.suc)
    pointwise_pow(f, n.suc) = compose(pow_real_fn(n.suc), f)
    derivative_pred((from_nat[Real](n.suc) * f(x0).pow(n)) * d, compose(pow_real_fn(n.suc), f))
    function_eq_transport_predicate_rev(
        derivative_pred((from_nat[Real](n.suc) * f(x0).pow(n)) * d),
        pointwise_pow(f, n.suc),
        compose(pow_real_fn(n.suc), f)
    )
    derivative_pred((from_nat[Real](n.suc) * f(x0).pow(n)) * d, pointwise_pow(f, n.suc))
    has_derivative_at(pointwise_pow(f, n.suc), x0, (from_nat[Real](n.suc) * f(x0).pow(n)) * d)
}

/// Positive natural powers preserve differentiability of real-valued functions.
theorem differentiable_pointwise_pow_suc(f: Real -> Real, n: Nat, x0: Real) {
    differentiable_at(f, x0) implies differentiable_at(pointwise_pow(f, n.suc), x0)
} by {
    let d: Real satisfy {
        has_derivative_at(f, x0, d)
    }
    derivative_pointwise_pow_suc(f, n, x0, d)
    has_derivative_at(pointwise_pow(f, n.suc), x0, (from_nat[Real](n.suc) * f(x0).pow(n)) * d)
    exists(e: Real) {
        has_derivative_at(pointwise_pow(f, n.suc), x0, e)
    }
}
