from set import Set
from topological_space import TopologicalSpace, closure
from countable import is_countable

/// True if `s` has a countable subset whose closure contains `s`.
define is_separable[T: TopologicalSpace](s: Set[T]) -> Bool {
    exists(d: Set[T]) {
        d.subset(s) and is_countable[T](d) and s.subset(closure(d))
    }
}
