from set import Set
from topological_space import TopologicalSpace, is_dense
from countable import is_countable

/// True if `s` admits a countable dense subset (a subset of `s` that is dense in `T`).
/// In particular, taking `s = Set[T].universal_set` recovers separability of the space.
define is_separable[T: TopologicalSpace](s: Set[T]) -> Bool {
    exists(d: Set[T]) {
        d.subset(s) and is_countable[T](d) and is_dense[T](d)
    }
}
