theorem relation_intersection_monotone_left[A, B](
    r1: (A, B) -> Bool,
    r2: (A, B) -> Bool,
    s: (A, B) -> Bool
) {
    relation_subset(r1, r2) implies
    relation_subset(relation_intersection(r1, s), relation_intersection(r2, s))
} by {
