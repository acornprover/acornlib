    (f.hom(a) = f.hom(b)) =
        (ring_hom_kernel_quotient_project(f, a) = ring_hom_kernel_quotient_project(f, b))
} by {
    ring_hom_kernel_quotient_induced_eq_iff_image_eq(f, a, b)
    ring_hom_kernel_quotient_induced_eq_iff_project_eq(f, a, b)
}

