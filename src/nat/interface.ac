/// Public interface for natural numbers.

// nat_base.ac
from add import Add
from functions import Inhabited
from lte import LTE
from mul import Mul
from order import PartialOrder, LinearOrder, is_monotone, is_order_embedding, is_strict_monotone
from relation_basic import is_reflexive, is_transitive, is_antisymmetric
from zero import Zero
