    is_monotone(nat_mul_right_map(a))
}

theorem lt_cancel_mul(a: Nat, b: Nat, c: Nat) {
    a != 0 and a * b < a * c implies b < c
}

theorem trichotomy(a: Nat, b: Nat) { a < b or b < a or a = b }

theorem lt_or_lte(a: Nat, b: Nat) { a < b or b <= a }

theorem lte_imp_not_lt(a: Nat, b: Nat) { a <= b implies not (b < a) }

theorem division_theorem(m: Nat, n: Nat) {
    0 < n implies exists(q: Nat, r: Nat) {
        r < n and m = q * n + r
    }
}

attributes Nat {
    /// True if this number is composite (has nontrivial factors).
    define is_composite(self) -> Bool {
        exists(b: Nat, c: Nat) {
            1 < b and 1 < c and self = b * c
        }
    }

    /// True if this number is prime (greater than 1 and not composite).
    define is_prime(self) -> Bool {
        1 < self and not self.is_composite
    }

    /// True if this number divides b (equivalently, there exists c such that this * c = b).
    define divides(self, b: Nat) -> Bool {
        exists(c: Nat) { self * c = b }
    }

    /// The factorial of this number (the product 1 * 2 * ... * n).
    define factorial(self) -> Nat {
        match self {
            Nat.zero {
                1
            }
            Nat.suc(pred) {
                self * pred.factorial
            }
        }
    }
}

theorem mul_to_zero(a: Nat, b: Nat) { a * b = 0 implies a = 0 or b = 0 }

theorem mul_to_one(a: Nat, b: Nat) { a * b = 1 implies a = 1 }

theorem divisor_lt(a: Nat, b: Nat, c: Nat) {
    a != 0 and 1 < b and a * b = c implies a < c
}

theorem divides_self(a: Nat) { a.divides(a) }

define true_below(f: Nat -> Bool, n: Nat) -> Bool {
    forall(x: Nat) { x < n implies f(x) }
}

theorem strong_induction(f: Nat -> Bool) {
    forall(k: Nat) {
        true_below(f, k) implies f(k)
    } implies forall(n: Nat) { f(n) }
}

theorem divides_trans(a: Nat, b: Nat, c: Nat) {
    a.divides(b) and b.divides(c) implies a.divides(c)
}

theorem has_prime_divisor(n: Nat) {
    1 < n implies exists(p: Nat) {
        p.is_prime and p.divides(n)
    }
}

theorem factorial_zero {
    0.factorial = 1
}

theorem factorial_one {
    1.factorial = 1
}

theorem factorial_step(n: Nat) {
    n.suc.factorial = n.suc * n.factorial
}

theorem divides_factorial(k: Nat, n: Nat) {
    k != 0 and k <= n implies k.divides(n.factorial)
}

theorem lte_one_factorial(a: Nat) { 1 <= a.factorial }

theorem exists_infinite_primes(n: Nat) {
    exists(p: Nat) {
        n < p and p.is_prime
    }
}

theorem divides_zero(a: Nat) {
    a.divides(0)
}

theorem zero_divides(a: Nat) { 0.divides(a) implies a = 0 }

theorem divides_mul(a: Nat, b: Nat, d: Nat) { d.divides(a) implies d.divides(a * b) }

theorem divides_lte(a: Nat, b: Nat) { a.divides(b) implies b = 0 or a <= b }

theorem divides_add(a: Nat, b: Nat, d: Nat) {
    d.divides(a) and d.divides(b) implies d.divides(a + b)
}

theorem divides_symm(a: Nat, b: Nat) { a.divides(b) and b.divides(a) implies a = b }

theorem sum_lte(a: Nat, b: Nat, c: Nat, d: Nat) { a <= c and b <= d implies a + b <= c + d }

theorem cross_sum_lte(a: Nat, b: Nat, c: Nat, d: Nat) {
    a + b = c + d and a <= c implies d <= b
}

let bounded_sub(a: Nat, b: Nat) -> d: Nat satisfy {
    if a < b {
        d = 0
    } else {
        d + b = a
    }
}

attributes Nat {
    /// Subtraction on natural numbers is defined oddly; it "caps out" at zero.
    /// If `self < b`, then `self - b = 0`.
    /// It would be better to define this as "not valid" on some inputs, but
    /// the language doesn't make that convenient yet.
    define sub(self, b: Nat) -> Nat { bounded_sub(self, b) }
}

theorem add_sub(a: Nat, b: Nat) {
    b <= a implies a - b + b = a
}

theorem sub_lt(a: Nat, b: Nat) { a < b implies a - b = 0 }

theorem sub_self(a: Nat) { a - a = 0 }

theorem sub_zero(a: Nat) {
    a - 0 = a
}

theorem alt_add_zero(a: Nat, b: Nat) {
    b != Nat.0 or a + b = a
}

theorem sub_pos(a: Nat, b: Nat) {
    a > b implies a - b > 0
}

theorem add_imp_sub(a: Nat, b: Nat, c: Nat) { a + b = c implies c - b = a }

theorem add_imp_sub_left(a: Nat, b: Nat, c: Nat) {
    a + b = c implies c - a = b
}

/// The successor of a number minus one equals the number.
theorem suc_sub_one(a: Nat) {
    a.suc - 1 = a
}

/// Subtracting two numbers can be done in either order, if both subtractions are bounded.
theorem sub_comm(a: Nat, b: Nat, c: Nat) {
    b + c <= a implies (a - b) - c = (a - c) - b
}

/// When n > 0, subtracting 1 gives a value less than n.
theorem sub_one_lt(n: Nat) {
    n > 0 implies n - 1 < n
}

/// Subtracting one and then any amount gives a smaller number, if the original number is positive.
theorem sub_one_sub_lt(n: Nat, x: Nat) {
    n > 0 implies n - 1 - x < n
}

let nat_mod(a: Nat, m: Nat) -> r: Nat satisfy {
    if m != 0 {
        r < m and exists(q: Nat) { q * m + r = a }
    } else {
        // It doesn't really matter how we define "mod 0".
        // We pick a mod 0 = a.
        r = a
    }
}

attributes Nat {
    /// The remainder when dividing this number by m.
    let mod = nat_mod
}

theorem add_mod(a: Nat, m: Nat) {
    exists(q: Nat) { q * m + a.mod(m) = a }
}

theorem mod_by_zero(a: Nat) { a.mod(0) = a }

theorem mod_of_zero(m: Nat) {
    0.mod(m) = 0
}

theorem div_sub_mod(a: Nat, m: Nat) { m.divides(a - a.mod(m)) }

theorem mod_lte(a: Nat, m: Nat) { a.mod(m) <= a }

theorem divides_sub(a: Nat, b: Nat, d: Nat) {
    d.divides(a) and d.divides(b) implies d.divides(a - b)
}

theorem divides_mod(a: Nat, m: Nat, d: Nat) {
    d.divides(a) and d.divides(m) implies d.divides(a.mod(m))
}

theorem div_imp_mod(a: Nat, m: Nat) { m.divides(a) implies a.mod(m) = 0 }

theorem small_mod(a: Nat, m: Nat) { a < m implies a.mod(m) = a }

theorem mod_mod(a: Nat, m: Nat) { a.mod(m).mod(m) = a.mod(m) }

theorem divides_unmod(d: Nat, a: Nat, m: Nat) {
    d.divides(m) and d.divides(a.mod(m)) implies d.divides(a)
}

theorem mul_cancel_left(a: Nat, b: Nat, c: Nat) {
    a != 0 and a * b = a * c implies b = c
}

theorem mul_cancel_right(a: Nat, b: Nat, c: Nat) {
    a != 0 and b * a = c * a implies b = c
}

theorem lte_mul(a: Nat, b: Nat) { b != 0 implies a <= a * b }

theorem divides_cancel_right(a: Nat, b: Nat, c: Nat) {
    a != 0 and (b * a).divides(c * a) implies b.divides(c)
}

theorem divides_mul_left(a: Nat, b: Nat, m: Nat) {
    a.divides(b) implies (m * a).divides(m * b)
}

theorem divides_mul_right(a: Nat, b: Nat, m: Nat) {
    a.divides(b) implies (a * m).divides(b * m)
}

instance Nat: LinearOrder


// gcd.ac
from pair import Pair

/// Performs one step of the Euclidean algorithm for computing GCD.
/// Takes the pair (a, b) and replaces it with (b, a mod b).
define gcd_step(p: Pair[Nat, Nat]) -> Pair[Nat, Nat] {
    if p.second = 0 {
        p
    } else {
        Pair.new(p.second, p.first.mod(p.second))
    }
}

/// Performs n steps of the Euclidean GCD algorithm.
define gcd_step_n(p: Pair[Nat, Nat], n: Nat) -> Pair[Nat, Nat] {
    match n {
        Nat.zero {
            p
        }
        Nat.suc(pred) {
            gcd_step(gcd_step_n(p, pred))
        }
    }
}

/// The Euclidean algorithm step viewed as a relation on pairs of natural numbers.
define gcd_step_relation(p: Pair[Nat, Nat], q: Pair[Nat, Nat]) -> Bool {
    gcd_step(p) = q
}

/// True if a predicate is false for all values below n.
define false_below(f: Nat -> Bool, n: Nat) -> Bool { forall(x: Nat) { x < n implies not f(x) } }

/// True if m is the smallest natural number for which the predicate f is true.
define is_min(f: Nat -> Bool, m: Nat) -> Bool {
    f(m) and false_below(f, m)
}

theorem has_min(f: Nat -> Bool, n: Nat) {
    f(n) implies exists(m: Nat) { is_min(f, m) }
}

define decreasing_to_zero(f: Nat -> Nat) -> Bool {
    forall(x: Nat) {
        f(x) = 0 or f(x.suc) < f(x)
    }
}

define gcd_termination(p: Pair[Nat, Nat]) -> (Nat -> Bool) {
    function(n: Nat) {
        gcd_step_n(p, n).second = 0
    }
}

let num_gcd_steps(p: Pair[Nat, Nat]) -> n: Nat satisfy {
    gcd_step_n(p, n).second = 0
}

define gcd_pair(p: Pair[Nat, Nat]) -> Nat { gcd_step_n(p, num_gcd_steps(p)).first }

attributes Nat {
    /// The greatest common divisor of this number and b.
    define gcd(self, b: Nat) -> Nat { gcd_pair(Pair.new(self, b)) }
}

define divides_both(a: Nat, p: Pair[Nat, Nat]) -> Bool {
    a.divides(p.first) and a.divides(p.second)
}

/// The relation that records preservation of a common divisor along Euclidean states.
define preserves_divides_both(d: Nat, p: Pair[Nat, Nat], q: Pair[Nat, Nat]) -> Bool {
    divides_both(d, p) implies divides_both(d, q)
}

theorem divides_gcd(d: Nat, a: Nat, b: Nat) {
    d.divides(a) and d.divides(b) implies d.divides(a.gcd(b))
}

theorem gcd_divides(d: Nat, a: Nat, b: Nat) {
    d.divides(a.gcd(b)) implies d.divides(a) and d.divides(b)
}

theorem gcd_divides_left(a: Nat, b: Nat) {
    a.gcd(b).divides(a)
}

theorem gcd_divides_right(a: Nat, b: Nat) {
    a.gcd(b).divides(b)
}

theorem gcd_nonzero_left(a: Nat, b: Nat) {
    a != 0 implies a.gcd(b) != 0
}

theorem gcd_zero_right(a: Nat) { a.gcd(0) = a }

theorem gcd_zero_left(a: Nat) { 0.gcd(a) = a }

theorem gcd_comm(a: Nat, b: Nat) { a.gcd(b) = b.gcd(a) }

theorem gcd_nonzero_right(a: Nat, b: Nat) { b != 0 implies a.gcd(b) != 0 }

attributes Nat {
    /// True if this number and b have no common factor greater than one.
    define coprime(self, b: Nat) -> Bool { self.gcd(b) = 1 }
}

define mod_maintains(f: Nat -> Bool) -> Bool {
    forall(a: Nat, b: Nat) { f(a) and f(b) implies f(a.mod(b)) }
}

theorem mod_maintains_imp_gcd(f: Nat -> Bool, a: Nat, b: Nat) {
    mod_maintains(f) and f(a) and f(b) implies f(a.gcd(b))
}

theorem gcd_one_right(a: Nat) {
    a.gcd(1) = 1
}

theorem gcd_one_left(a: Nat) {
    1.gcd(a) = 1
}

theorem gcd_mult_right(a: Nat, b: Nat, m: Nat) {
    a.gcd(b) * m = (a * m).gcd(b * m)
}

theorem gcd_mult_left(a: Nat, b: Nat, m: Nat) {
    m * a.gcd(b) = (m * a).gcd(m * b)
}

theorem cofactor(a: Nat, b: Nat, af: Nat, bf: Nat) {
    (
        a.gcd(b) != 0 and
        af * a.gcd(b) = a and
        bf * a.gcd(b) = b
    ) implies af.gcd(bf) = 1
}

theorem gcd_of_prime(p: Nat, n: Nat) {
    p.is_prime implies p.gcd(n) = 1 or p.divides(n)
}


// lcm.ac
/// The least common multiple of two natural numbers, characterised by
/// `a.gcd(b) * lcm(a, b) = a * b`. When both inputs are zero the gcd is also
/// zero and the equation collapses; we pick `lcm(0, 0) = 0` by convention.
let nat_lcm(a: Nat, b: Nat) -> l: Nat satisfy {
    if a.gcd(b) = Nat.0 {
        l = Nat.0
    } else {
        a.gcd(b) * l = a * b
    }
}

attributes Nat {
    /// The least common multiple of this number and b.
    let lcm = nat_lcm
}

/// The defining equation for lcm: gcd times lcm equals the product.
theorem gcd_mul_lcm(a: Nat, b: Nat) {
    a.gcd(b) * a.lcm(b) = a * b
}


// nat_monoid.ac
from comm_monoid import CommMonoid
from monoid import Monoid, MonoidHom
from semigroup import Semigroup

attributes M: Monoid {
    /// Raises a monoid element to a natural number power using repeated multiplication.
    define pow(self, exp: Nat) -> M {
        match exp {
            Nat.zero {
                M.1
            }
            Nat.suc(n) {
                self * self.pow(n)
            }
        }
    }
}

theorem pow_one[M: Monoid](a: M) {
    a.pow(Nat.1) = a
}

theorem pow_zero[M: Monoid](a: M) {
    a.pow(Nat.0) = M.1
}

theorem pow_add[M: Monoid](a: M, n: Nat, m: Nat) {
    a.pow(n) * a.pow(m) = a.pow(n + m)
}

theorem pow_pow[M: Monoid](a: M, n: Nat, m: Nat) {
    a.pow(n).pow(m) = a.pow(n * m)
}

theorem one_pow[M: Monoid](n: Nat) {
    M.1.pow(n) = M.1
}

theorem pow_distrib_mul[M: CommMonoid](a: M, b: M, c: Nat) {
    (a * b).pow(c) = a.pow(c) * b.pow(c)
}

instance Nat: Semigroup

instance Nat: Monoid

