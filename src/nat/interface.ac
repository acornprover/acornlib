// lattice.ac
from add_semigroup import AddSemigroup
from add_comm_semigroup import AddCommSemigroup
from add_monoid import AddMonoid
from add_comm_monoid import AddCommMonoid
from semiring import Semiring
from comm_semigroup import CommSemigroup
from lattice import Meet, Join, MeetSemilattice, JoinSemilattice, Lattice, DistribLattice
from order import min_lte_left, min_lte_right, lte_min_of_bounds, lte_max_left, lte_max_right,
    max_lte_of_upper_bounds, min_max_distrib_left, max_min_distrib_left

instance Nat: AddSemigroup

instance Nat: AddCommSemigroup

instance Nat: AddMonoid

instance Nat: AddCommMonoid

instance Nat: Semiring

instance Nat: CommSemigroup

instance Nat: CommMonoid

instance Nat: Meet {
    define meet(self, other: Nat) -> Nat {
        self.min(other)
    }
}

instance Nat: Join {
    define join(self, other: Nat) -> Nat {
        self.max(other)
    }
}

instance Nat: MeetSemilattice

instance Nat: JoinSemilattice

instance Nat: Lattice

instance Nat: DistribLattice

theorem nat_lte_meet_of_bounds(c: Nat, a: Nat, b: Nat) {
    c <= a and c <= b implies c <= a.meet(b)
}

/// The left argument is at most the join.
theorem nat_lte_join_left(a: Nat, b: Nat) {
    a <= a.join(b)
}

/// The right argument is at most the join.
theorem nat_lte_join_right(a: Nat, b: Nat) {
    b <= a.join(b)
}

/// The join is the least upper bound.
theorem nat_join_lte_of_bounds(a: Nat, b: Nat, c: Nat) {
    a <= c and b <= c implies a.join(b) <= c
}


// semiring.ac
/// A nonzero power of zero in a semiring is zero.
theorem semiring_zero_pow[S: Semiring](n: Nat) {
    n != Nat.0 implies S.0.pow(n) = S.0
}

/// Standard embedding of the natural numbers into a semiring.
define from_nat[S: Semiring](n: Nat) -> S {
    match n {
        Nat.zero {
            S.0
        }
        Nat.suc(pred) {
            from_nat[S](pred) + S.1
        }
    }
}

/// The image of zero in a semiring is zero.
theorem from_nat_zero[S: Semiring] {
    from_nat[S](Nat.0) = S.0
}

/// from_nat maps 1 to the one of the semiring.
theorem from_nat_one[S: Semiring] {
    from_nat[S](Nat.1) = S.1
}

/// from_nat preserves addition.
theorem from_nat_add[S: Semiring](m: Nat, n: Nat) {
    from_nat[S](m + n) = from_nat[S](m) + from_nat[S](n)
}

/// from_nat preserves multiplication.
theorem from_nat_mul[S: Semiring](m: Nat, n: Nat) {
    from_nat[S](m * n) = from_nat[S](m) * from_nat[S](n)
}
