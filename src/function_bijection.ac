from functions import Inhabited, identity_fn, compose, compose_assoc,
    compose_identity_left, compose_identity_right, function_extensionality,
    is_injective_fn, is_surjective_fn, is_bijection_fn,
    is_injective, is_surjective, is_bijection,
    is_injective_eq_is_injective_fn, is_surjective_eq_is_surjective_fn,
    is_bijection_eq_is_bijection_fn,
    Bijection, bijection_new_self, bijection_ext,
    bijection_map_is_injective,
    identity_bijection, identity_bijection_map,
    inverse_bijection, inverse_bijection_apply_image, bijection_apply_inverse,
    compose_bijection, compose_bijection_map,
    injective_fn_eq

/// The identity function is injective.
theorem identity_fn_is_injective_fn[T] {
    is_injective_fn(identity_fn[T])
} by {
    forall(x: T, y: T) {
        if identity_fn[T](x) = identity_fn[T](y) {
            identity_fn[T](x) = x
            identity_fn[T](y) = y
            x = y
        }
    }
}

/// The identity function is surjective.
theorem identity_fn_is_surjective_fn[T] {
    is_surjective_fn(identity_fn[T])
} by {
    forall(y: T) {
        identity_fn[T](y) = y
        exists(x: T) {
            identity_fn[T](x) = y
        }
    }
}

/// The identity function is bijective.
theorem identity_fn_is_bijection_fn[T] {
    is_bijection_fn(identity_fn[T])
} by {
    identity_fn_is_injective_fn[T]
    identity_fn_is_surjective_fn[T]
}

/// The identity endofunction is injective.
theorem identity_fn_is_injective[T] {
    is_injective(identity_fn[T])
} by {
    is_injective_eq_is_injective_fn(identity_fn[T])
    identity_fn_is_injective_fn[T]
}

/// The identity endofunction is surjective.
theorem identity_fn_is_surjective[T] {
    is_surjective(identity_fn[T])
} by {
    is_surjective_eq_is_surjective_fn(identity_fn[T])
    identity_fn_is_surjective_fn[T]
}

/// The identity endofunction is bijective.
theorem identity_fn_is_bijection[T] {
    is_bijection(identity_fn[T])
} by {
    is_bijection_eq_is_bijection_fn(identity_fn[T])
    identity_fn_is_bijection_fn[T]
}

/// The identity bijection is constructible from the identity map.
theorem identity_bijection_new[T](anchor: T) {
    Bijection[T, T].new(identity_fn[T]) = Option.some(identity_bijection(anchor))
} by {
    identity_bijection_map(anchor)
    bijection_new_self(identity_bijection(anchor))
}

/// The identity bijection applies as the identity function.
theorem identity_bijection_apply[T](anchor: T, x: T) {
    identity_bijection(anchor).map(x) = x
} by {
    identity_bijection_map(anchor)
}

/// A composite bijection applies as the composite of the underlying maps.
theorem compose_bijection_apply[T, U, V](e: Bijection[U, V], h: Bijection[T, U], x: T) {
    compose_bijection(e, h).map(x) = e.map(h.map(x))
} by {
    compose_bijection_map(e, h)
    compose_bijection(e, h).map = compose(e.map, h.map)
    compose(e.map, h.map, x) = e.map(h.map(x))
}

/// Identity bijection is a left identity for bijection composition.
theorem compose_bijection_identity_left[T, U](e: Bijection[T, U], anchor: U) {
    compose_bijection(identity_bijection(anchor), e) = e
} by {
    compose_bijection_map(identity_bijection(anchor), e)
    identity_bijection_map(anchor)
    compose_identity_left(e.map)
    compose_bijection(identity_bijection(anchor), e).map = e.map
    bijection_ext(compose_bijection(identity_bijection(anchor), e), e)
}

/// Identity bijection is a right identity for bijection composition.
theorem compose_bijection_identity_right[T, U](e: Bijection[T, U], anchor: T) {
    compose_bijection(e, identity_bijection(anchor)) = e
} by {
    compose_bijection_map(e, identity_bijection(anchor))
    identity_bijection_map(anchor)
    compose_identity_right(e.map)
    compose_bijection(e, identity_bijection(anchor)).map = e.map
    bijection_ext(compose_bijection(e, identity_bijection(anchor)), e)
}

/// Bijection composition is associative.
theorem compose_bijection_assoc[A, B, C, D](
    f: Bijection[C, D], g: Bijection[B, C], h: Bijection[A, B]
) {
    compose_bijection(f, compose_bijection(g, h)) = compose_bijection(compose_bijection(f, g), h)
} by {
    compose_bijection_map(f, compose_bijection(g, h))
    compose_bijection_map(g, h)
    compose_bijection_map(compose_bijection(f, g), h)
    compose_bijection_map(f, g)
    compose_assoc(f.map, g.map, h.map)
    compose_bijection(f, compose_bijection(g, h)).map =
        compose_bijection(compose_bijection(f, g), h).map
    bijection_ext(compose_bijection(f, compose_bijection(g, h)), compose_bijection(compose_bijection(f, g), h))
}

/// The inverse bijection is a left inverse for composition.
theorem compose_bijection_inverse_left[T: Inhabited, U](e: Bijection[T, U], anchor: T) {
    compose_bijection(inverse_bijection(e), e) = identity_bijection(anchor)
} by {
    forall(x: T) {
        compose_bijection(inverse_bijection(e), e).map(x) = inverse_bijection(e).map(e.map(x))
        inverse_bijection_apply_image(e, x)
        identity_bijection_apply(anchor, x)
        compose_bijection(inverse_bijection(e), e).map(x) = identity_bijection(anchor).map(x)
    }
    function_extensionality(compose_bijection(inverse_bijection(e), e).map, identity_bijection(anchor).map)
    bijection_ext(compose_bijection(inverse_bijection(e), e), identity_bijection(anchor))
}

/// The inverse bijection is a right inverse for composition.
theorem compose_bijection_inverse_right[T: Inhabited, U](e: Bijection[T, U], anchor: U) {
    compose_bijection(e, inverse_bijection(e)) = identity_bijection(anchor)
} by {
    forall(y: U) {
        compose_bijection(e, inverse_bijection(e)).map(y) = e.map(inverse_bijection(e).map(y))
        bijection_apply_inverse(e, y)
        identity_bijection_apply(anchor, y)
        compose_bijection(e, inverse_bijection(e)).map(y) = identity_bijection(anchor).map(y)
    }
    function_extensionality(compose_bijection(e, inverse_bijection(e)).map, identity_bijection(anchor).map)
    bijection_ext(compose_bijection(e, inverse_bijection(e)), identity_bijection(anchor))
}

/// Inverting a bijection twice returns the original bijection.
theorem inverse_bijection_involutive[T: Inhabited, U: Inhabited](e: Bijection[T, U]) {
    inverse_bijection(inverse_bijection(e)) = e
} by {
    forall(x: T) {
        inverse_bijection(e).map(inverse_bijection(inverse_bijection(e)).map(x)) = x
        inverse_bijection_apply_image(e, x)
        bijection_map_is_injective(inverse_bijection(e))
        injective_fn_eq(inverse_bijection(e).map, inverse_bijection(inverse_bijection(e)).map(x), e.map(x))
        inverse_bijection(inverse_bijection(e)).map(x) = e.map(x)
    }
    function_extensionality(inverse_bijection(inverse_bijection(e)).map, e.map)
    bijection_ext(inverse_bijection(inverse_bijection(e)), e)
}
