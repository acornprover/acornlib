/// `>=` splits into the disjunction of equality and strict greater-than.
theorem gte_iff_eq_or_gt[P: PartialOrder](a: P, b: P) {
    a >= b = (a = b or a > b)
}

/// `a <= b` together with `a != b` upgrades to `a < b`.
theorem lt_of_lte_of_ne[P: PartialOrder](a: P, b: P) {
