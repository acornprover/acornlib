}

/// `<` is the asymmetric part of `<=`: `a < b` iff not `b <= a` and `a <= b`.
theorem lt_iff_lte_not_lte_swap[P: PartialOrder](a: P, b: P) {
    a < b = (not (b <= a) and a <= b)
}

