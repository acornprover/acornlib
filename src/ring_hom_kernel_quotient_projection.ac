/// Projection-facing negation and multiplication simplifications for
/// ring-kernel quotients.

from ring import Ring
from ring_hom import RingHom
from quotient_algebra import ring_hom_kernel_quotient_add,
    ring_hom_kernel_quotient_sub,
    ring_hom_kernel_quotient_mul,
    ring_hom_kernel_quotient_neg,
    ring_hom_kernel_quotient_project,
    ring_hom_kernel_quotient_neg_add_projection,
    ring_hom_kernel_quotient_neg_sub_projection,
    ring_hom_kernel_quotient_sub_neg_projection,
    ring_hom_kernel_quotient_neg_mul,
    ring_hom_kernel_quotient_mul_neg,
    ring_hom_kernel_quotient_neg_mul_neg

/// Negation distributes over addition of projected ring-kernel representatives.
theorem ring_hom_kernel_quotient_project_neg_add_projection[R: Ring, S: Ring](
    f: RingHom[R, S], a: R, b: R
) {
    ring_hom_kernel_quotient_neg(f,
        ring_hom_kernel_quotient_add(f,
            ring_hom_kernel_quotient_project(f, a),
            ring_hom_kernel_quotient_project(f, b))) =
    ring_hom_kernel_quotient_add(f,
        ring_hom_kernel_quotient_neg(f, ring_hom_kernel_quotient_project(f, a)),
        ring_hom_kernel_quotient_neg(f, ring_hom_kernel_quotient_project(f, b)))
} by {
    ring_hom_kernel_quotient_neg_add_projection(f, a, b)
}

/// Negation sends subtraction of projected ring-kernel representatives to the opposite subtraction.
theorem ring_hom_kernel_quotient_project_neg_sub_projection[R: Ring, S: Ring](
    f: RingHom[R, S], a: R, b: R
) {
    ring_hom_kernel_quotient_neg(f,
        ring_hom_kernel_quotient_sub(f,
            ring_hom_kernel_quotient_project(f, a),
            ring_hom_kernel_quotient_project(f, b))) =
    ring_hom_kernel_quotient_sub(f,
        ring_hom_kernel_quotient_project(f, b),
        ring_hom_kernel_quotient_project(f, a))
} by {
    ring_hom_kernel_quotient_neg_sub_projection(f, a, b)
}

/// Subtracting a negated projected ring-kernel representative is quotient addition.
theorem ring_hom_kernel_quotient_project_sub_neg_projection[R: Ring, S: Ring](
    f: RingHom[R, S], a: R, b: R
) {
    ring_hom_kernel_quotient_sub(f,
        ring_hom_kernel_quotient_project(f, a),
        ring_hom_kernel_quotient_neg(f, ring_hom_kernel_quotient_project(f, b))) =
    ring_hom_kernel_quotient_add(f,
        ring_hom_kernel_quotient_project(f, a),
        ring_hom_kernel_quotient_project(f, b))
} by {
    ring_hom_kernel_quotient_sub_neg_projection(f, a, b)
}

/// Multiplying by a negated projected ring-kernel representative on the left negates the product.
theorem ring_hom_kernel_quotient_project_neg_mul[R: Ring, S: Ring](
    f: RingHom[R, S], a: R, b: R
) {
    ring_hom_kernel_quotient_mul(f,
        ring_hom_kernel_quotient_neg(f, ring_hom_kernel_quotient_project(f, a)),
        ring_hom_kernel_quotient_project(f, b)) =
    ring_hom_kernel_quotient_neg(f,
        ring_hom_kernel_quotient_mul(f,
            ring_hom_kernel_quotient_project(f, a),
            ring_hom_kernel_quotient_project(f, b)))
} by {
    ring_hom_kernel_quotient_neg_mul(f, a, b)
}

/// Multiplying by a negated projected ring-kernel representative on the right negates the product.
theorem ring_hom_kernel_quotient_project_mul_neg[R: Ring, S: Ring](
    f: RingHom[R, S], a: R, b: R
) {
    ring_hom_kernel_quotient_mul(f,
        ring_hom_kernel_quotient_project(f, a),
        ring_hom_kernel_quotient_neg(f, ring_hom_kernel_quotient_project(f, b))) =
    ring_hom_kernel_quotient_neg(f,
        ring_hom_kernel_quotient_mul(f,
            ring_hom_kernel_quotient_project(f, a),
            ring_hom_kernel_quotient_project(f, b)))
} by {
    ring_hom_kernel_quotient_mul_neg(f, a, b)
}

/// Multiplying two negated projected ring-kernel representatives gives the original product.
theorem ring_hom_kernel_quotient_project_neg_mul_neg[R: Ring, S: Ring](
    f: RingHom[R, S], a: R, b: R
) {
    ring_hom_kernel_quotient_mul(f,
        ring_hom_kernel_quotient_neg(f, ring_hom_kernel_quotient_project(f, a)),
        ring_hom_kernel_quotient_neg(f, ring_hom_kernel_quotient_project(f, b))) =
    ring_hom_kernel_quotient_mul(f,
        ring_hom_kernel_quotient_project(f, a),
        ring_hom_kernel_quotient_project(f, b))
} by {
    ring_hom_kernel_quotient_neg_mul_neg(f, a, b)
}
