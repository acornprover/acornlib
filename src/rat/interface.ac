theorem rat_neg_one {
    -Rat.1 = Rat.from_int(-Int.1)
}

theorem mul_neg_one_right(r: Rat) {
    r * -Rat.1 = -r
}

theorem mul_neg_one_left(r: Rat) {
    -Rat.1 * r = -r
