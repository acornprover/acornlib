from set import Set
from pair import Pair
from topological_space import box, box_contains_eq

/// Hard problem: product boxes are monotone in both factors.
theorem box_mono[X, Y](u1: Set[X], u2: Set[X], v1: Set[Y], v2: Set[Y]) {
    u1.subset(u2) and v1.subset(v2) implies box(u1, v1).subset(box(u2, v2))
} by {
    if u1.subset(u2) and v1.subset(v2) {
        forall(p: Pair[X, Y]) {
            if box(u1, v1).contains(p) {
                box_contains_eq(u1, v1, p)
                box_contains_eq(u2, v2, p)
                u1.contains(p.first)
                v1.contains(p.second)
                u2.contains(p.first)
                v2.contains(p.second)
                box(u2, v2).contains(p)
            }
        }
    }
}
